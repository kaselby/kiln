#!/usr/bin/env bash
# ---
# name: tool-info
# brief: Show full tool details on demand
# description: Show full tool details (description, arguments, usage) on demand. Use when you need parameter syntax or usage guidance for a tool. Complements the brief tool listing in your context.
# arguments: "<tool-name> | --list [--full]"
# ---
#
# Usage:
#   tool-info fetch          Show full header for 'fetch'
#   tool-info --list         List all tools with brief descriptions
#   tool-info --list --full  List all tools with full descriptions
#

set -euo pipefail

TOOLS_DIR="${AGENT_HOME:-$HOME}/tools"

find_tool() {
    local name="$1"
    for dir in "$TOOLS_DIR/core" "$TOOLS_DIR/library" "$TOOLS_DIR"; do
        if [[ -f "$dir/$name" ]]; then
            echo "$dir/$name"
            return 0
        fi
    done
    return 1
}

show_tool() {
    local name="$1"
    local tool_path
    tool_path=$(find_tool "$name") || {
        echo "Error: tool '$name' not found in $TOOLS_DIR" >&2
        exit 1
    }

    # Extract header block between # --- delimiters
    local in_header=false
    local header=""
    while IFS= read -r line; do
        if [[ "$line" =~ ^[[:space:]]*#[[:space:]]*---[[:space:]]*$ ]]; then
            if $in_header; then
                break
            fi
            in_header=true
            continue
        fi
        if $in_header; then
            if [[ "$line" =~ ^[[:space:]]*#[[:space:]] ]]; then
                header+="${line#*# }"$'\n'
            else
                break
            fi
        fi
    done < "$tool_path"

    if [[ -z "$header" ]]; then
        echo "No header found for tool '$name'"
        return
    fi

    echo "=== $name ==="
    echo "$header"

    # Also show usage comments after the header (lines starting with # before code)
    local past_header=false
    local in_usage=false
    while IFS= read -r line; do
        if [[ "$line" =~ ^[[:space:]]*#[[:space:]]*---[[:space:]]*$ ]]; then
            if $past_header; then
                past_header="done"
                continue
            fi
            past_header=true
            continue
        fi
        if [[ "$past_header" == "done" ]]; then
            if [[ "$line" =~ ^[[:space:]]*#(.*)$ ]]; then
                local comment="${BASH_REMATCH[1]}"
                if [[ -z "$comment" ]] && ! $in_usage; then
                    continue
                fi
                in_usage=true
                echo "$comment"
            elif [[ -z "$line" ]] && $in_usage; then
                echo ""
            else
                break
            fi
        fi
    done < "$tool_path"
}

list_tools() {
    local full="${1:-false}"

    for tool_path in "$TOOLS_DIR"/core/* "$TOOLS_DIR"/library/* "$TOOLS_DIR"/*; do
        [[ -f "$tool_path" ]] || continue
        [[ "$(basename "$tool_path")" == "registry.yml" ]] && continue

        local name
        name=$(basename "$tool_path")

        # Parse header
        local in_header=false
        local tool_name="" brief="" description="" arguments="" cost=""
        while IFS= read -r line; do
            if [[ "$line" =~ ^[[:space:]]*#[[:space:]]*---[[:space:]]*$ ]]; then
                if $in_header; then break; fi
                in_header=true
                continue
            fi
            if $in_header && [[ "$line" =~ ^[[:space:]]*#[[:space:]](.+)$ ]]; then
                local content="${BASH_REMATCH[1]}"
                case "$content" in
                    name:*) tool_name="${content#name: }" ;;
                    brief:*) brief="${content#brief: }" ;;
                    description:*) description="${content#description: }" ;;
                    arguments:*) arguments="${content#arguments: }"; arguments="${arguments//\"/}" ;;
                    cost:*) cost="${content#cost: }" ;;
                esac
            fi
        done < "$tool_path"

        [[ -z "$tool_name" ]] && continue

        if [[ "$full" == "true" ]]; then
            local cost_tag=""
            [[ -n "$cost" ]] && cost_tag=" [\$$cost/call]"
            local args=""
            [[ -n "$arguments" ]] && args=" \`$arguments\`"
            echo "- **${tool_name}**${args} — ${description}${cost_tag}"
        else
            local display="${brief:-$description}"
            local cost_tag=""
            [[ -n "$cost" ]] && cost_tag=" [\$$cost/call]"
            echo "- **${tool_name}** — ${display}${cost_tag}"
        fi
    done
}

# --- Main ---
if [[ $# -eq 0 ]]; then
    echo "Usage: tool-info <tool-name> | --list [--full]"
    exit 1
fi

case "$1" in
    --list)
        full="false"
        [[ "${2:-}" == "--full" ]] && full="true"
        list_tools "$full"
        ;;
    *)
        show_tool "$1"
        ;;
esac
