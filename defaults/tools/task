#!/usr/bin/env python3
# ---
# name: task
# description: Atomic TODO.yml task operations with file locking. Prevents concurrent edit conflicts.
# arguments: "<claim|release|status|list> [task-id] [options]"
# ---
#
# Usage:
#   task list [todo-file]                      List all tasks with status
#   task claim <task-id> [todo-file]           Claim a task (sets assignee + in-progress)
#   task release <task-id> [todo-file]         Release a claimed task (clears assignee, sets open)
#   task status <task-id> <status> [todo-file] Update task status (open/in-progress/done/blocked)
#
# If todo-file is omitted, searches for TODO.yml or todo.yaml in the current directory.
# All write operations use fcntl file locking for safe concurrent access.

import fcntl
import os
import sys
from pathlib import Path

import yaml


VALID_STATUSES = {"open", "in-progress", "done", "blocked"}


def find_todo_file(explicit: str | None = None) -> Path:
    """Find the TODO.yml file, searching cwd if not specified."""
    if explicit:
        p = Path(explicit)
        if not p.exists():
            print(f"Error: {explicit} not found", file=sys.stderr)
            sys.exit(1)
        return p

    for name in ("TODO.yml", "todo.yaml", "TODO.yaml", "todo.yml"):
        p = Path(name)
        if p.exists():
            return p

    print("Error: no TODO.yml found in current directory", file=sys.stderr)
    sys.exit(1)


def load_todo(path: Path) -> dict:
    """Load and parse a TODO.yml file."""
    text = path.read_text()
    data = yaml.safe_load(text)
    if not data or "tasks" not in data:
        print(f"Error: {path} has no 'tasks' key", file=sys.stderr)
        sys.exit(1)
    return data


def find_task(tasks: list, task_id: str) -> dict | None:
    """Find a task by ID, searching subtasks recursively."""
    for task in tasks:
        tid = str(task.get("id", ""))
        if tid == task_id:
            return task
        subtasks = task.get("subtasks", [])
        if subtasks:
            found = find_task(subtasks, task_id)
            if found:
                return found
    return None


def atomic_update(path: Path, updater) -> None:
    """Read-lock-modify-write a TODO.yml file atomically.

    updater is called with the parsed data dict and should modify it in place.
    Returns whatever updater returns.
    """
    with open(path, "r+") as f:
        fcntl.flock(f, fcntl.LOCK_EX)
        try:
            data = yaml.safe_load(f.read())
            if not data or "tasks" not in data:
                print(f"Error: {path} has no 'tasks' key", file=sys.stderr)
                sys.exit(1)

            result = updater(data)

            f.seek(0)
            f.truncate()
            # Preserve comment header by writing it back manually
            yaml.dump(data, f, default_flow_style=False, sort_keys=False, allow_unicode=True)

            return result
        finally:
            fcntl.flock(f, fcntl.LOCK_UN)


def cmd_list(args: list) -> None:
    """List all tasks."""
    todo_file = args[0] if args else None
    path = find_todo_file(todo_file)
    data = load_todo(path)

    def print_tasks(tasks, indent=0):
        for task in tasks:
            tid = task.get("id", "?")
            desc = task.get("description", "")
            status = task.get("status", "?")
            assignee = task.get("assignee", "")
            prefix = "  " * indent
            assignee_str = f" ({assignee})" if assignee else ""
            print(f"{prefix}[{status}] {tid}: {desc}{assignee_str}")
            if task.get("subtasks"):
                print_tasks(task["subtasks"], indent + 1)

    print_tasks(data["tasks"])


def cmd_claim(args: list) -> None:
    """Claim a task atomically."""
    if not args:
        print("Error: task claim requires a task ID", file=sys.stderr)
        sys.exit(1)

    task_id = args[0]
    todo_file = args[1] if len(args) > 1 else None
    path = find_todo_file(todo_file)
    agent_id = os.environ.get("AGENT_ID", "unknown")

    def updater(data):
        task = find_task(data["tasks"], task_id)
        if not task:
            print(f"Error: task {task_id} not found", file=sys.stderr)
            sys.exit(1)

        current_assignee = task.get("assignee")
        if current_assignee and current_assignee != agent_id:
            print(
                f"Error: task {task_id} already claimed by {current_assignee}",
                file=sys.stderr,
            )
            sys.exit(1)

        task["assignee"] = agent_id
        task["status"] = "in-progress"

    atomic_update(path, updater)
    print(f"Claimed task {task_id} as {agent_id}")


def cmd_release(args: list) -> None:
    """Release a claimed task atomically."""
    if not args:
        print("Error: task release requires a task ID", file=sys.stderr)
        sys.exit(1)

    task_id = args[0]
    todo_file = args[1] if len(args) > 1 else None
    path = find_todo_file(todo_file)

    def updater(data):
        task = find_task(data["tasks"], task_id)
        if not task:
            print(f"Error: task {task_id} not found", file=sys.stderr)
            sys.exit(1)

        task.pop("assignee", None)
        task["status"] = "open"

    atomic_update(path, updater)
    print(f"Released task {task_id}")


def cmd_status(args: list) -> None:
    """Update task status atomically."""
    if len(args) < 2:
        print("Error: task status requires <task-id> <status>", file=sys.stderr)
        sys.exit(1)

    task_id = args[0]
    new_status = args[1]
    todo_file = args[2] if len(args) > 2 else None

    if new_status not in VALID_STATUSES:
        print(
            f"Error: invalid status '{new_status}'. "
            f"Valid: {', '.join(sorted(VALID_STATUSES))}",
            file=sys.stderr,
        )
        sys.exit(1)

    path = find_todo_file(todo_file)

    def updater(data):
        task = find_task(data["tasks"], task_id)
        if not task:
            print(f"Error: task {task_id} not found", file=sys.stderr)
            sys.exit(1)
        task["status"] = new_status

    atomic_update(path, updater)
    print(f"Task {task_id} status → {new_status}")


COMMANDS = {
    "list": cmd_list,
    "claim": cmd_claim,
    "release": cmd_release,
    "status": cmd_status,
}


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print("Usage: task <list|claim|release|status> [args...]")
        print()
        print("Commands:")
        print("  list [todo-file]                      List all tasks")
        print("  claim <task-id> [todo-file]           Claim a task")
        print("  release <task-id> [todo-file]         Release a task")
        print("  status <task-id> <status> [todo-file] Update task status")
        sys.exit(0)

    cmd = sys.argv[1]
    if cmd not in COMMANDS:
        print(f"Error: unknown command '{cmd}'", file=sys.stderr)
        sys.exit(1)

    COMMANDS[cmd](sys.argv[2:])


if __name__ == "__main__":
    main()
