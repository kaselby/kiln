#!/usr/bin/env bash
# ---
# name: list-sessions
# description: List session summaries, most recent first
# arguments: "[-n <count>] [--all]"
# ---
#
# Usage: list-sessions          → last 10 sessions
#        list-sessions -n 5     → last 5 sessions
#        list-sessions --all    → all sessions

set -euo pipefail

SESSIONS_DIR="${AGENT_HOME:?}/memory/sessions"
COUNT=10

while [[ $# -gt 0 ]]; do
    case "$1" in
        -n) COUNT="$2"; shift 2 ;;
        --all) COUNT=0; shift ;;
        *) echo "Usage: list-sessions [-n COUNT | --all]" >&2; exit 1 ;;
    esac
done

if [[ ! -d "$SESSIONS_DIR" ]]; then
    echo "No sessions directory at $SESSIONS_DIR"
    exit 0
fi

files=($(ls -r "$SESSIONS_DIR"/*.md 2>/dev/null))

if [[ ${#files[@]} -eq 0 ]]; then
    echo "No session summaries found."
    exit 0
fi

if [[ $COUNT -gt 0 ]]; then
    files=("${files[@]:0:$COUNT}")
fi

for f in "${files[@]}"; do
    basename="${f##*/}"
    # Extract first heading or first non-empty line as title
    title=$(grep -m1 '^#' "$f" 2>/dev/null | sed 's/^#* *//' || head -1 "$f")
    printf "%-45s %s\n" "$basename" "$title"
done
