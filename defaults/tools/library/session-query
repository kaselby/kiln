#!/usr/bin/env python3
# ---
# name: session-query
# description: Query past session conversations. Extract readable text or ask questions about what happened.
# arguments: "<extract|ask> <agent-id-pattern> [question]"
# ---
"""Query past session conversations (the "seance" pattern).

Usage:
  session-query list                          List available sessions
  session-query extract <pattern>             Extract conversation as readable text
  session-query extract <pattern> --compact   Shorter format (no tool calls)
  session-query ask <pattern> "question"      Ask a question about the session
  session-query ask <pattern> "question" --model opus   Use a specific model (default: sonnet)

Pattern matching:
  Full agent ID:    session-query extract kiln-thorn-crow
  Date prefix:      session-query extract 2026-03-02       (lists matches if multiple)
  Partial match:    session-query extract thorn             (fuzzy match on agent ID)

The 'ask' subcommand pipes the extracted conversation to `claude -p` with your
question. Uses the default model (subscription). Cost: ~10-30K input tokens per query.
"""

import json
import os
import subprocess
import sys
import tempfile
from pathlib import Path

AGENT_HOME = Path(os.environ.get("AGENT_HOME", Path.home() / ".agent"))
LOGS_DIR = AGENT_HOME / "logs" / "conversations"
REGISTRY_PATH = AGENT_HOME / "logs" / "session-registry.json"
CLAUDE_PROJECTS = Path.home() / ".claude" / "projects"


def _find_live_jsonl(agent_id: str) -> Path | None:
    """Find the live JSONL for a running agent via the session registry."""
    if not REGISTRY_PATH.exists():
        return None
    try:
        registry = json.loads(REGISTRY_PATH.read_text())
    except (json.JSONDecodeError, OSError):
        return None

    entry = registry.get(agent_id)
    if not entry:
        return None

    session_uuid = entry.get("session_uuid")
    cwd = entry.get("cwd", "")
    if not session_uuid or not cwd:
        return None

    encoded_cwd = str(Path(cwd).resolve()).replace("/", "-").replace(".", "-")
    jsonl_path = CLAUDE_PROJECTS / encoded_cwd / f"{session_uuid}.jsonl"
    return jsonl_path if jsonl_path.exists() else None


def _get_running_agents() -> list[str]:
    """Get agent IDs of running tmux sessions."""
    try:
        result = subprocess.run(
            ["tmux", "list-sessions", "-F", "#{session_name}"],
            capture_output=True, text=True, timeout=5,
        )
        if result.returncode != 0:
            return []
        return [s for s in result.stdout.strip().splitlines() if s.startswith(os.environ.get("AGENT_PREFIX", "agent-"))]
    except (OSError, subprocess.TimeoutExpired):
        return []


def find_sessions(pattern: str) -> list[Path]:
    """Find session log files matching a pattern.

    Checks archived logs first, then falls back to live session JSONLs
    via the session registry for currently-running agents.
    """
    archived = []
    if LOGS_DIR.exists():
        archived = sorted(LOGS_DIR.glob("*.jsonl"))

    # Exact match on stem (archived)
    exact = [f for f in archived if f.stem == pattern]
    if exact:
        return exact

    # Prefix match (e.g., date prefix "2026-03-02")
    prefix = [f for f in archived if f.stem.startswith(pattern)]
    if prefix:
        return prefix

    # Substring match (e.g., "thorn" matches "2026-03-02-kiln-thorn-crow")
    substr = [f for f in archived if pattern in f.stem]
    if substr:
        return substr

    # No archived match — check live sessions
    running = _get_running_agents()
    live_matches = [a for a in running if pattern in a]
    if live_matches:
        results = []
        for agent_id in live_matches:
            path = _find_live_jsonl(agent_id)
            if path:
                results.append(path)
        if results:
            return results

    return []


def extract_conversation(filepath: Path, compact: bool = False) -> str:
    """Extract readable conversation text from a JSONL log file."""
    lines = []
    with open(filepath) as f:
        for raw_line in f:
            obj = json.loads(raw_line.strip())
            msg_type = obj.get("type")
            if msg_type not in ("user", "assistant"):
                continue

            msg = obj.get("message", {})
            role = msg.get("role", "?")
            content = msg.get("content", "")
            ts = obj.get("timestamp", "")

            texts = []
            has_tool = False

            if isinstance(content, list):
                for block in content:
                    if not isinstance(block, dict):
                        continue
                    btype = block.get("type")
                    if btype == "text":
                        text = block["text"].strip()
                        if text:
                            texts.append(text)
                    elif btype == "tool_use":
                        has_tool = True
                        if not compact:
                            name = block.get("name", "?")
                            inp = block.get("input", {})
                            # Show tool name and key arguments
                            if "command" in inp:
                                texts.append(f"[{name}: {inp['command'][:120]}]")
                            elif "file_path" in inp:
                                texts.append(f"[{name}: {inp['file_path']}]")
                            elif "query" in inp:
                                texts.append(f"[{name}: {inp['query'][:120]}]")
                            else:
                                texts.append(f"[{name}]")
                    elif btype == "tool_result":
                        pass  # Skip tool results — too verbose
                    elif btype == "thinking":
                        if not compact:
                            thought = block.get("thinking", "")
                            if thought:
                                # Show first line of thinking
                                first_line = thought.split("\n")[0][:150]
                                texts.append(f"(thinking: {first_line})")
            elif isinstance(content, str):
                text = content.strip()
                if text:
                    texts.append(text)

            if not texts:
                continue

            # Skip pure tool-call messages in compact mode
            if compact and has_tool and not any(
                not t.startswith("[") and not t.startswith("(") for t in texts
            ):
                continue

            prefix = "USER" if role == "user" else "AGENT"
            body = "\n".join(texts)

            # In compact mode, strip system-reminder content from user messages
            if compact and role == "user":
                # Filter out hook feedback, system reminders
                filtered = []
                for t in texts:
                    if t.startswith("Stop hook feedback:"):
                        continue
                    if "<system-reminder>" in t:
                        continue
                    if t.startswith("[tool_result"):
                        continue
                    filtered.append(t)
                if not filtered:
                    continue
                body = "\n".join(filtered)

            lines.append(f"[{ts[:19]}] {prefix}:\n{body}\n")

    return "\n".join(lines)


def cmd_list():
    """List available session logs."""
    if not LOGS_DIR.exists():
        print("No conversation logs found.")
        return

    files = sorted(LOGS_DIR.glob("*.jsonl"))
    if not files:
        print("No conversation logs found.")
        return

    for f in files:
        # Quick stats
        msg_count = 0
        try:
            with open(f) as fh:
                for line in fh:
                    obj = json.loads(line.strip())
                    if obj.get("type") in ("user", "assistant"):
                        msg_count += 1
        except (json.JSONDecodeError, OSError):
            msg_count = -1
        print(f"  {f.stem}  ({msg_count} messages)")


def cmd_extract(pattern: str, compact: bool = False):
    """Extract and print a session conversation."""
    matches = find_sessions(pattern)
    if not matches:
        print(f"No sessions matching '{pattern}'.", file=sys.stderr)
        sys.exit(1)
    if len(matches) > 1:
        print(f"Multiple sessions match '{pattern}':", file=sys.stderr)
        for m in matches:
            print(f"  {m.stem}", file=sys.stderr)
        print(f"\nBe more specific, or use the full name.", file=sys.stderr)
        sys.exit(1)

    text = extract_conversation(matches[0], compact=compact)
    print(f"# Session: {matches[0].stem}\n")
    print(text)


def cmd_ask(pattern: str, question: str, model: str = "sonnet"):
    """Ask a question about a past session.

    Defaults to Sonnet — sufficient for Q&A over conversation logs and
    much cheaper than Opus. Use --model opus for nuanced analysis.
    """
    matches = find_sessions(pattern)
    if not matches:
        print(f"No sessions matching '{pattern}'.", file=sys.stderr)
        sys.exit(1)
    if len(matches) > 1:
        print(f"Multiple sessions match '{pattern}':", file=sys.stderr)
        for m in matches:
            print(f"  {m.stem}", file=sys.stderr)
        print(f"\nBe more specific.", file=sys.stderr)
        sys.exit(1)

    # Extract compact conversation
    conversation = extract_conversation(matches[0], compact=True)
    session_name = matches[0].stem

    # Build the prompt
    prompt = f"""You are reviewing a conversation log from an AI agent session.
Session: {session_name}

Answer the following question based on the conversation below.
Be specific and cite relevant parts of the conversation.

Question: {question}

---
CONVERSATION LOG:
{conversation}"""

    # Write to temp file and pipe to claude -p
    with tempfile.NamedTemporaryFile(mode="w", suffix=".txt", delete=False) as tmp:
        tmp.write(prompt)
        tmp_path = tmp.name

    try:
        # Strip CLAUDECODE to allow nested invocation
        env = {k: v for k, v in os.environ.items() if k != "CLAUDECODE"}
        result = subprocess.run(
            ["claude", "-p", "--model", model, "--no-session-persistence",
             f"Read the file at {tmp_path} and answer the question it contains."],
            capture_output=True,
            text=True,
            env=env,
            stdin=subprocess.DEVNULL,
            timeout=120,
        )
        if result.returncode != 0:
            print(f"Error from claude: {result.stderr}", file=sys.stderr)
            sys.exit(1)
        print(result.stdout)
    finally:
        os.unlink(tmp_path)


def main():
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    cmd = args[0]

    if cmd == "list":
        cmd_list()
    elif cmd == "extract":
        if len(args) < 2:
            print("Usage: session-query extract <pattern> [--compact]", file=sys.stderr)
            sys.exit(1)
        compact = "--compact" in args
        pattern = args[1]
        cmd_extract(pattern, compact=compact)
    elif cmd == "ask":
        if len(args) < 3:
            print('Usage: session-query ask <pattern> "question" [--model sonnet|opus|haiku]', file=sys.stderr)
            sys.exit(1)
        # Extract --model flag
        model = "sonnet"
        remaining = []
        i = 1
        while i < len(args):
            if args[i] == "--model" and i + 1 < len(args):
                model = args[i + 1]
                i += 2
            else:
                remaining.append(args[i])
                i += 1
        if len(remaining) < 2:
            print('Usage: session-query ask <pattern> "question" [--model sonnet|opus|haiku]', file=sys.stderr)
            sys.exit(1)
        pattern = remaining[0]
        question = " ".join(remaining[1:])
        cmd_ask(pattern, question, model=model)
    else:
        print(f"Unknown command: {cmd}", file=sys.stderr)
        print("Commands: list, extract, ask", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
