#!/usr/bin/env python3
# ---
# name: log-analysis
# description: Analyze agent observability logs — tool usage, session stats, conversation content
# arguments: "<subcommand> [options]"
# ---
"""Analyze agent observability logs.

Subcommands:
  tools          Custom tool & skill usage summary
  sessions       List archived conversation sessions with stats
  conversation   Extract specific content from a conversation log

All data comes from the agent logs directory..
"""

import argparse
import json
import sys
from collections import Counter
from datetime import datetime, timedelta
from pathlib import Path

LOGS_DIR = Path(os.environ.get('AGENT_HOME', str(Path.home() / '.agent'))) / 'logs'
TOOL_USAGE_FILE = LOGS_DIR / "tool-usage.jsonl"
CONVERSATIONS_DIR = LOGS_DIR / "conversations"


def parse_since(since_str: str) -> datetime:
    """Parse a relative time string like '7d', '24h', '30d' into a datetime."""
    unit = since_str[-1]
    amount = int(since_str[:-1])
    if unit == "d":
        return datetime.now() - timedelta(days=amount)
    elif unit == "h":
        return datetime.now() - timedelta(hours=amount)
    elif unit == "w":
        return datetime.now() - timedelta(weeks=amount)
    else:
        print(f"Unknown time unit '{unit}'. Use d (days), h (hours), w (weeks).", file=sys.stderr)
        sys.exit(1)


def load_tool_usage(since: datetime | None = None) -> list[dict]:
    """Load tool usage entries, optionally filtered by time."""
    if not TOOL_USAGE_FILE.exists():
        return []
    entries = []
    for line in TOOL_USAGE_FILE.read_text().splitlines():
        if not line.strip():
            continue
        entry = json.loads(line)
        if since:
            ts = datetime.fromisoformat(entry["ts"])
            if ts < since:
                continue
        entries.append(entry)
    return entries


# ---- Subcommand: tools ----

def cmd_tools(args):
    since = parse_since(args.since) if args.since else None
    entries = load_tool_usage(since)

    if not entries:
        period = f" (since {args.since})" if args.since else ""
        print(f"No custom tool/skill usage recorded{period}.")
        return

    # Split by type
    tools = [e for e in entries if e.get("type") == "tool"]
    skills = [e for e in entries if e.get("type") == "skill"]

    if tools:
        print("Custom Tools:")
        tool_counts = Counter(e["name"] for e in tools)
        tool_errors = Counter(e["name"] for e in tools if e.get("error"))
        for name, count in tool_counts.most_common():
            errors = tool_errors.get(name, 0)
            err_str = f"  ({errors} errors)" if errors else ""
            print(f"  {name:<20} {count:>4} calls{err_str}")
        print()

    if skills:
        print("Skill Activations:")
        skill_counts = Counter(e["name"] for e in skills)
        for name, count in skill_counts.most_common():
            print(f"  {name:<20} {count:>4} activations")
        print()

    # Per-agent breakdown if multiple agents
    agents = set(e.get("agent", "") for e in entries)
    if len(agents) > 1:
        print(f"Across {len(agents)} agents: {', '.join(sorted(agents))}")


# ---- Subcommand: sessions ----

def cmd_sessions(args):
    if not CONVERSATIONS_DIR.exists():
        print("No archived conversations found.")
        return

    files = sorted(CONVERSATIONS_DIR.glob("*.jsonl"), reverse=True)
    if args.since:
        since = parse_since(args.since)
        files = [f for f in files if datetime.fromtimestamp(f.stat().st_mtime) >= since]

    limit = args.n or 10
    files = files[:limit]

    if not files:
        print("No conversations match the criteria.")
        return

    for f in files:
        stats = _session_stats(f)
        print(f"{f.stem}")
        print(f"  Turns: {stats['turns']}  |  "
              f"Input: {_fmt_tokens(stats['input_tokens'])}  |  "
              f"Output: {_fmt_tokens(stats['output_tokens'])}  |  "
              f"Tool calls: {stats['tool_calls']}  |  "
              f"Errors: {stats['errors']}")
        if stats['tools_used']:
            print(f"  Tools: {', '.join(sorted(stats['tools_used']))}")
        print()


def _session_stats(path: Path) -> dict:
    """Extract summary stats from a conversation JSONL file."""
    turns = 0
    input_tokens = 0
    output_tokens = 0
    tool_calls = 0
    errors = 0
    tools_used = set()

    for line in path.read_text().splitlines():
        if not line.strip():
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue

        etype = entry.get("type", "")

        if etype == "user":
            msg = entry.get("message", {})
            content = msg.get("content", "")
            # Plain text user message = a conversational turn
            if isinstance(content, str) and content.strip():
                turns += 1
            # Count tool result errors
            if isinstance(content, list):
                for block in content:
                    if isinstance(block, dict) and block.get("type") == "tool_result":
                        if block.get("is_error"):
                            errors += 1

        elif etype == "assistant":
            msg = entry.get("message", {})
            usage = msg.get("usage", {})
            if usage:
                input_tokens += usage.get("input_tokens", 0)
                input_tokens += usage.get("cache_read_input_tokens", 0)
                input_tokens += usage.get("cache_creation_input_tokens", 0)
                output_tokens += usage.get("output_tokens", 0)

            # Count tool use blocks
            content = msg.get("content", [])
            if isinstance(content, list):
                for block in content:
                    if isinstance(block, dict) and block.get("type") == "tool_use":
                        tool_calls += 1
                        tools_used.add(block.get("name", "unknown"))

    return {
        "turns": turns,
        "input_tokens": input_tokens,
        "output_tokens": output_tokens,
        "tool_calls": tool_calls,
        "errors": errors,
        "tools_used": tools_used,
    }


# ---- Subcommand: conversation ----

def cmd_conversation(args):
    # Find the conversation file
    path = _resolve_conversation(args.session)
    if not path:
        print(f"No conversation found matching '{args.session}'.", file=sys.stderr)
        sys.exit(1)

    if args.mode == "user-messages":
        _show_user_messages(path, args.limit)
    elif args.mode == "errors":
        _show_errors(path)
    elif args.mode == "tools":
        _show_tool_calls(path, args.limit)
    elif args.mode == "text":
        _show_assistant_text(path, args.limit)
    elif args.mode == "dialogue":
        _show_dialogue(path, args.limit, getattr(args, "max_chars", 0))
    else:
        print(f"Unknown mode '{args.mode}'. Use: user-messages, errors, tools, text, dialogue", file=sys.stderr)
        sys.exit(1)


def _resolve_conversation(session: str) -> Path | None:
    """Resolve a session identifier to a conversation file.

    Accepts: full filename, agent ID fragment, or 'latest'.
    """
    if not CONVERSATIONS_DIR.exists():
        return None

    if session == "latest":
        files = sorted(CONVERSATIONS_DIR.glob("*.jsonl"), reverse=True)
        return files[0] if files else None

    # Try exact filename
    exact = CONVERSATIONS_DIR / session
    if exact.exists():
        return exact
    exact_jsonl = CONVERSATIONS_DIR / f"{session}.jsonl"
    if exact_jsonl.exists():
        return exact_jsonl

    # Try matching agent ID fragment
    matches = [f for f in CONVERSATIONS_DIR.glob("*.jsonl") if session in f.stem]
    if len(matches) == 1:
        return matches[0]
    if len(matches) > 1:
        print(f"Ambiguous match for '{session}':", file=sys.stderr)
        for m in sorted(matches):
            print(f"  {m.name}", file=sys.stderr)
        return None

    return None


def _show_user_messages(path: Path, limit: int):
    """Show user messages from a conversation."""
    messages = []
    for line in path.read_text().splitlines():
        if not line.strip():
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue
        if entry.get("type") == "user":
            msg = entry.get("message", {})
            content = msg.get("content", "")
            if isinstance(content, str) and content.strip():
                ts = entry.get("timestamp", "")
                messages.append((ts, content))

    for ts, content in messages[-limit:]:
        t = ts.split("T")[1][:8] if "T" in ts else ts
        print(f"[{t}] {content[:200]}")
        if len(content) > 200:
            print(f"  ... ({len(content)} chars total)")
        print()


def _show_errors(path: Path):
    """Show all tool errors from a conversation."""
    found = False
    for line in path.read_text().splitlines():
        if not line.strip():
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue
        if entry.get("type") == "user":
            msg = entry.get("message", {})
            content = msg.get("content", "")
            if isinstance(content, list):
                for block in content:
                    if isinstance(block, dict) and block.get("type") == "tool_result" and block.get("is_error"):
                        found = True
                        error_content = block.get("content", "")
                        if isinstance(error_content, list):
                            error_content = " ".join(
                                b.get("text", "") for b in error_content if isinstance(b, dict)
                            )
                        print(f"Error: {str(error_content)[:500]}")
                        print()

    if not found:
        print("No errors found in this conversation.")


def _show_tool_calls(path: Path, limit: int):
    """Show tool calls from a conversation."""
    calls = []
    for line in path.read_text().splitlines():
        if not line.strip():
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue
        if entry.get("type") == "assistant":
            msg = entry.get("message", {})
            content = msg.get("content", [])
            if isinstance(content, list):
                for block in content:
                    if isinstance(block, dict) and block.get("type") == "tool_use":
                        ts = entry.get("timestamp", "")
                        name = block.get("name", "unknown")
                        inp = block.get("input", {})
                        calls.append((ts, name, inp))

    for ts, name, inp in calls[-limit:]:
        t = ts.split("T")[1][:8] if "T" in ts else ts
        # Compact input display
        if name == "Bash":
            detail = inp.get("command", "")[:100]
        elif name == "Read":
            detail = inp.get("file_path", "")
        elif name == "Edit":
            detail = inp.get("file_path", "")
        elif name == "Write":
            detail = inp.get("file_path", "")
        else:
            detail = json.dumps(inp, separators=(",", ":"))[:100]
        print(f"[{t}] {name}: {detail}")


def _show_dialogue(path: Path, limit: int, max_chars: int):
    """Show interleaved user + assistant dialogue, skipping tool calls/results."""
    messages = []
    for line in path.read_text().splitlines():
        if not line.strip():
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue

        etype = entry.get("type", "")
        ts = entry.get("timestamp", "")

        if etype == "user":
            msg = entry.get("message", {})
            content = msg.get("content", "")
            # Only plain text user messages (skip tool results)
            if isinstance(content, str) and content.strip():
                messages.append(("user", ts, content))

        elif etype == "assistant":
            msg = entry.get("message", {})
            content = msg.get("content", [])
            if isinstance(content, list):
                text_parts = []
                for block in content:
                    if isinstance(block, dict) and block.get("type") == "text":
                        text_parts.append(block.get("text", ""))
                if text_parts:
                    messages.append(("assistant", ts, "\n".join(text_parts)))

    if limit and len(messages) > limit:
        messages = messages[-limit:]

    for role, ts, text in messages:
        t = ts.split("T")[1][:8] if "T" in ts else ts
        label = "USER" if role == "user" else "AGENT"
        if max_chars and len(text) > max_chars:
            display = text[:max_chars] + f"\n  ... ({len(text)} chars total)"
        else:
            display = text
        print(f"[{t}] {label}:")
        for line in display.split("\n"):
            print(f"  {line}")
        print()


def _show_assistant_text(path: Path, limit: int):
    """Show assistant text responses (no tool calls) from a conversation."""
    messages = []
    for line in path.read_text().splitlines():
        if not line.strip():
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue
        if entry.get("type") == "assistant":
            msg = entry.get("message", {})
            content = msg.get("content", [])
            if isinstance(content, list):
                text_parts = []
                for block in content:
                    if isinstance(block, dict) and block.get("type") == "text":
                        text_parts.append(block.get("text", ""))
                if text_parts:
                    ts = entry.get("timestamp", "")
                    messages.append((ts, "\n".join(text_parts)))

    for ts, text in messages[-limit:]:
        t = ts.split("T")[1][:8] if "T" in ts else ts
        preview = text[:300].replace("\n", " ")
        print(f"[{t}] {preview}")
        if len(text) > 300:
            print(f"  ... ({len(text)} chars total)")
        print()


# ---- Utilities ----

def _fmt_tokens(n: int) -> str:
    if n < 1000:
        return str(n)
    if n < 10000:
        return f"{n / 1000:.1f}k"
    return f"{n // 1000}k"


# ---- Main ----

def main():
    parser = argparse.ArgumentParser(
        prog="log-analysis",
        description="Analyze agent observability logs.",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    # tools
    p_tools = sub.add_parser("tools", help="Custom tool & skill usage summary")
    p_tools.add_argument("--since", help="Time window (e.g. 7d, 24h, 2w)")

    # sessions
    p_sessions = sub.add_parser("sessions", help="List archived conversations with stats")
    p_sessions.add_argument("-n", type=int, help="Number of sessions to show (default 10)")
    p_sessions.add_argument("--since", help="Time window (e.g. 7d, 24h, 2w)")

    # conversation
    p_conv = sub.add_parser("conversation", help="Extract content from a conversation log")
    p_conv.add_argument("session", help="Session identifier: filename, agent ID fragment, or 'latest'")
    p_conv.add_argument("mode", choices=["user-messages", "errors", "tools", "text", "dialogue"],
                        help="What to extract")
    p_conv.add_argument("--limit", type=int, default=50, help="Max items to show (default 50)")
    p_conv.add_argument("--max-chars", type=int, default=0,
                        help="Truncate messages to N chars (0=no limit, default 0). Useful for dialogue mode.")

    args = parser.parse_args()

    if args.command == "tools":
        cmd_tools(args)
    elif args.command == "sessions":
        cmd_sessions(args)
    elif args.command == "conversation":
        cmd_conversation(args)


if __name__ == "__main__":
    main()
