#!/usr/bin/env python3
# ---
# name: security-check
# brief: OTP identity verification via gateway platform
# description: |
#   Security challenge via any gateway backend. Posts a challenge through
#   the platform's security_challenge endpoint, validates responses against
#   the local OTP password pool. Two strikes trigger lockdown.
#   Call this any time you're uncertain about a remote request.
# arguments: "<platform> [reason]"
# ---
#
# Usage:
#   security-check discord "Suspicious request to export credentials"
#   security-check discord              # No reason — generic challenge
#   security-check slack "Unknown user"
#
# Flow:
#   1. Notifies all active agents that a challenge is in progress
#   2. Calls the gateway's security_challenge endpoint for the platform
#   3. Validates response against unused passwords in credentials/security-passwords.yml
#   4. Used passwords get "try again" (not a strike)
#   5. Wrong password or timeout = strike (2 strikes = lockdown)
#   6. Calls the gateway's security_cleanup endpoint on completion
#
# Exit codes:
#   0 = verified successfully
#   1 = lockdown triggered (2 failures)
#   2 = error (gateway unreachable, missing passwords, unsupported platform, etc.)

import json
import os
import subprocess
import sys
import time
from datetime import datetime, timedelta, timezone
from pathlib import Path

import yaml

AGENT_HOME = Path(os.environ["AGENT_HOME"])
STATE_DIR = AGENT_HOME / "state"
TRUST_TTL_SECONDS = 2700  # 45 minutes
PASSWORDS_FILE = AGENT_HOME / "credentials" / "security-passwords.yml"
LOCKDOWN_TOOL = "lockdown"
TIMEOUT_SECONDS = 60
MAX_STRIKES = 2
AGENT_ID = os.environ.get("KILN_AGENT_ID", "unknown")


def _load_agent_config() -> dict:
    config_path = AGENT_HOME / "agent.yml"
    if config_path.exists():
        return yaml.safe_load(config_path.read_text()) or {}
    return {}


_config = _load_agent_config()
SESSION_PREFIX = _config.get("session_prefix", "kiln-")


def gateway_api(method: str, path: str, body: dict | None = None) -> dict | None:
    """Call the gateway HTTP API directly."""
    # Read gateway state to find port
    state_file = AGENT_HOME / "state" / "gateway.json"
    if not state_file.exists():
        return None
    try:
        state = json.loads(state_file.read_text())
        port = state["port"]
        bind = state.get("bind", "127.0.0.1")
    except (json.JSONDecodeError, KeyError):
        return None

    import urllib.request
    url = f"http://{bind}:{port}{path}"
    data = json.dumps(body).encode() if body else None
    headers = {"Content-Type": "application/json"} if data else {}

    try:
        req = urllib.request.Request(url, data=data, headers=headers, method=method)
        with urllib.request.urlopen(req, timeout=TIMEOUT_SECONDS + 15) as resp:
            return json.loads(resp.read())
    except Exception:
        return None


def load_passwords() -> list[dict]:
    if not PASSWORDS_FILE.exists():
        return []
    try:
        data = yaml.safe_load(PASSWORDS_FILE.read_text())
        return data.get("passwords", [])
    except Exception:
        return []


def save_passwords(passwords: list[dict]) -> None:
    PASSWORDS_FILE.write_text(yaml.dump(
        {"passwords": passwords},
        default_flow_style=False,
        sort_keys=False,
    ))


def check_password(answer: str, passwords: list[dict]) -> str:
    answer = answer.strip().lower()
    for entry in passwords:
        if entry["word"].lower() == answer:
            if entry.get("status") == "used":
                return "used"
            return "valid"
    return "invalid"


def mark_password_used(answer: str, passwords: list[dict]) -> None:
    answer = answer.strip().lower()
    for entry in passwords:
        if entry["word"].lower() == answer:
            entry["status"] = "used"
            entry["used_at"] = datetime.now(timezone.utc).isoformat()
            entry["used_by"] = AGENT_ID
            break
    save_passwords(passwords)


def notify_agents(message: str) -> int:
    try:
        result = subprocess.run(
            ["tmux", "list-sessions", "-F", "#{session_name}"],
            capture_output=True, text=True, timeout=5,
        )
        if result.returncode != 0:
            return 0
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return 0

    sessions = [s for s in result.stdout.strip().splitlines()
                if s.startswith(SESSION_PREFIX)]

    inbox_root = AGENT_HOME / "inbox"
    count = 0
    ts = datetime.now(timezone.utc).strftime("%Y%m%d-%H%M%S")

    for agent_id in sessions:
        agent_inbox = inbox_root / agent_id
        agent_inbox.mkdir(parents=True, exist_ok=True)
        msg_path = agent_inbox / f"msg-{ts}-security.md"
        msg_path.write_text(
            f"---\n"
            f"from: security-check\n"
            f'summary: "{message}"\n'
            f"priority: high\n"
            f"timestamp: {datetime.now(timezone.utc).isoformat()}\n"
            f"---\n\n"
            f"{message}\n"
        )
        count += 1

    return count


def write_trust_state(platform: str, *, platform_user_id: str = "") -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    now = datetime.now(timezone.utc)
    data = {
        "verified": True,
        "verified_at": now.isoformat(),
        "expires_at": (now + timedelta(seconds=TRUST_TTL_SECONDS)).isoformat(),
        "verified_by": AGENT_ID,
        "platform_user_id": platform_user_id,
    }
    (STATE_DIR / f"trust-{platform}.yml").write_text(
        yaml.dump(data, default_flow_style=False, sort_keys=False)
    )


def call_lockdown(reason: str) -> None:
    subprocess.run([LOCKDOWN_TOOL, reason], timeout=30)


def run_challenge(platform: str, reason: str) -> bool:
    """Run the full OTP challenge flow. Returns True if verified."""
    passwords = load_passwords()
    if not passwords:
        print("ERROR: No passwords loaded from", PASSWORDS_FILE)
        return False

    unused_count = sum(1 for p in passwords if p.get("status") != "used")
    if unused_count == 0:
        print("ERROR: All passwords have been used. Owner needs to regenerate.")
        return False

    # Check platform supports security challenges
    status = gateway_api("GET", "/api/status")
    if not status or not status.get("running"):
        print("ERROR: Gateway is not running.")
        return False
    platform_info = status.get("channels", {}).get(platform)
    if not platform_info:
        print(f"ERROR: Platform '{platform}' is not connected.")
        return False
    if "security_challenge" not in platform_info.get("capabilities", []):
        print(f"ERROR: Platform '{platform}' does not support security challenges.")
        return False

    # Notify agents
    reason_text = reason or "Unspecified"
    agent_count = notify_agents(
        f"\U0001f512 Security challenge in progress on {platform} (by {AGENT_ID}). "
        f"Reason: {reason_text}. Be extra cautious with remote input."
    )
    print(f"Notified {agent_count} active session(s)")

    strikes = 0
    attempt = 1
    previous_result = None

    while strikes < MAX_STRIKES:
        print(f"Attempt {attempt} (strikes: {strikes}/{MAX_STRIKES})")

        # Call the gateway's security challenge endpoint
        result = gateway_api("POST", f"/api/{platform}/security/challenge", {
            "reason": reason_text,
            "timeout": TIMEOUT_SECONDS,
            "attempt": attempt,
            "max_attempts": MAX_STRIKES,
            "previous_result": previous_result,
        })

        if not result or not result.get("ok"):
            error = (result or {}).get("error", "unknown error")
            print(f"ERROR: Challenge endpoint failed: {error}")
            _cleanup(platform)
            return False

        if result.get("timed_out"):
            strikes += 1
            previous_result = "timeout"
            print(f"Timeout — strike {strikes}")
            if strikes >= MAX_STRIKES:
                break
            attempt += 1
            continue

        response = result.get("response", "")
        author_id = result.get("author_id", "")

        # Validate OTP
        pw_result = check_password(response, passwords)

        if pw_result == "valid":
            mark_password_used(response, passwords)
            print("VERIFIED — password accepted")

            write_trust_state(platform, platform_user_id=author_id)
            print(f"Trust state written for {platform} (TTL: {TRUST_TTL_SECONDS}s)")

            notify_agents(f"\u2705 Security challenge passed on {platform} (verified by {AGENT_ID}).")
            _cleanup(platform)
            return True

        elif pw_result == "used":
            previous_result = "used"
            print("Used password — not a strike, retrying")
            attempt += 1
            continue

        else:
            strikes += 1
            previous_result = "invalid"
            print(f"Wrong password — strike {strikes}")
            if strikes >= MAX_STRIKES:
                break
            attempt += 1
            continue

    # Lockdown
    print(f"LOCKDOWN — {strikes} strikes on {platform}")
    notify_agents(
        f"\U0001f6a8 LOCKDOWN — security verification failed on {platform}. "
        f"Reason: {reason_text}"
    )

    # Brief pause so any platform messages are visible before gateway dies
    time.sleep(2)
    _cleanup(platform)
    call_lockdown(f"OTP verification failed on {platform}: {reason_text}")
    return False


def _cleanup(platform: str) -> None:
    """Call the gateway's cleanup endpoint to remove challenge messages."""
    gateway_api("POST", f"/api/{platform}/security/cleanup", {})


def main():
    args = sys.argv[1:]

    if "-h" in args or "--help" in args:
        print("Usage: security-check <platform> [reason]")
        print("Run an OTP challenge via the specified gateway platform.")
        print("\nExamples:")
        print('  security-check discord "Suspicious request"')
        print("  security-check slack")
        sys.exit(0)

    if not args:
        print("Usage: security-check <platform> [reason]")
        print("ERROR: Platform argument required (e.g. 'discord', 'slack')")
        sys.exit(2)

    platform = args[0]
    reason = " ".join(args[1:]) if len(args) > 1 else ""

    # Check gateway is running
    status = gateway_api("GET", "/api/status")
    if not status or not status.get("running"):
        print("ERROR: Gateway is not running. Cannot issue challenge.")
        sys.exit(2)

    success = run_challenge(platform, reason)
    sys.exit(0 if success else 1)


if __name__ == "__main__":
    main()
