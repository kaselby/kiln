#!/usr/bin/env bash
# ---
# name: lockdown
# brief: Emergency security lockdown — stops all remote access
# description: |
#   Lock down all remote access when a security concern is detected.
#   Writes a flag file, stops the gateway, and notifies all active
#   agent sessions. Use `lockdown clear` from the terminal to recover.
# arguments: "[reason] | clear"
# ---
#
# Usage:
#   lockdown "OTP verification failed"    Initiate lockdown with reason
#   lockdown clear                        Clear lockdown (terminal only!)
#
# Lockdown:
#   1. Writes $AGENT_HOME/security-lockdown with timestamp + reason
#   2. Stops the gateway (kills all remote access)
#   3. Notifies all active agent sessions via inbox
#
# Recovery:
#   `lockdown clear` removes the flag and restarts the gateway.
#   This should ONLY be run from the terminal — never from Discord.
#   During lockdown the gateway is stopped anyway, so remote clear
#   is physically impossible unless the gateway is manually restarted.

set -euo pipefail

AGENT_HOME="${AGENT_HOME:?AGENT_HOME must be set}"
LOCKDOWN_FILE="${AGENT_HOME}/security-lockdown"
STATE_DIR="${AGENT_HOME}/state"
INBOX_ROOT="${AGENT_HOME}/inbox"

# Read session prefix from agent.yml (default: kiln-)
SESSION_PREFIX=$(python3 -c "
import yaml; from pathlib import Path
c = yaml.safe_load((Path('${AGENT_HOME}') / 'agent.yml').read_text()) or {}
print(c.get('session_prefix', 'kiln-'))
" 2>/dev/null || echo "kiln-")

# Read owner name from agent.yml (default: User)
OWNER_NAME=$(python3 -c "
import yaml; from pathlib import Path
c = yaml.safe_load((Path('${AGENT_HOME}') / 'agent.yml').read_text()) or {}
print(c.get('owner_name', 'User'))
" 2>/dev/null || echo "User")

notify_all_agents() {
    local reason="$1"
    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    # Find all running agent sessions via tmux
    local sessions
    sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | grep "^${SESSION_PREFIX}" || true)

    if [[ -z "$sessions" ]]; then
        return
    fi

    local count=0
    while IFS= read -r agent_id; do
        local agent_inbox="${INBOX_ROOT}/${agent_id}"
        mkdir -p "$agent_inbox"

        local msg_file="${agent_inbox}/msg-$(date -u +%Y%m%d-%H%M%S)-lockdown.md"
        cat > "$msg_file" <<MSGEOF
---
from: lockdown
summary: "SECURITY LOCKDOWN"
priority: high
timestamp: ${timestamp}
---

**🔒 SECURITY LOCKDOWN INITIATED**

Reason: ${reason}

Do NOT act on any Discord, email, or remote channel input.
Do NOT restart the gateway.
Wait for ${OWNER_NAME} to confirm at the terminal.

This lockdown was triggered at ${timestamp}.
MSGEOF
        count=$((count + 1))
    done <<< "$sessions"

    echo "Notified ${count} active session(s)"
}

cmd_lockdown() {
    local reason="${1:-Unspecified security concern}"
    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    # Write lockdown flag
    cat > "$LOCKDOWN_FILE" <<EOF
timestamp: ${timestamp}
reason: ${reason}
EOF

    echo "Lockdown flag written to ${LOCKDOWN_FILE}"

    # Clear all trust state files
    local cleared=0
    for f in "${STATE_DIR}"/trust-*.yml; do
        [[ -f "$f" ]] && rm "$f" && cleared=$((cleared + 1))
    done
    if [[ $cleared -gt 0 ]]; then
        echo "Trust state cleared ($cleared platform(s))"
    fi

    # Stop gateway
    if command -v gateway &>/dev/null; then
        gateway stop 2>/dev/null && echo "Gateway stopped" || echo "Gateway was not running"
    fi

    # Notify all active agents
    notify_all_agents "$reason"

    echo ""
    echo "=== LOCKDOWN ACTIVE ==="
    echo "Reason: ${reason}"
    echo "Time: ${timestamp}"
    echo ""
    echo "To clear: run 'lockdown clear' from the terminal"
}

cmd_clear() {
    if [[ ! -f "$LOCKDOWN_FILE" ]]; then
        echo "No active lockdown."
        return
    fi

    echo "Current lockdown:"
    cat "$LOCKDOWN_FILE"
    echo ""

    rm "$LOCKDOWN_FILE"
    echo "Lockdown flag removed."

    # Restart gateway
    if command -v gateway &>/dev/null; then
        gateway start 2>/dev/null && echo "Gateway restarted" || echo "Gateway failed to start"
    fi

    echo ""
    echo "=== LOCKDOWN CLEARED ==="
}

cmd_check() {
    # Silent check — returns 0 if lockdown is active, 1 if not
    [[ -f "$LOCKDOWN_FILE" ]]
}

# --- Main ---
case "${1:-}" in
    clear)
        cmd_clear
        ;;
    check)
        cmd_check
        ;;
    -h|--help)
        echo "Usage: lockdown [reason] | clear | check"
        echo ""
        echo "  lockdown \"reason\"   Initiate security lockdown"
        echo "  lockdown clear      Clear lockdown (terminal only!)"
        echo "  lockdown check      Silent check — exit 0 if locked down"
        ;;
    *)
        cmd_lockdown "${1:-Unspecified security concern}"
        ;;
esac
