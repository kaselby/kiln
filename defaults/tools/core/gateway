#!/usr/bin/env python3
# ---
# name: gateway
# brief: Discord messaging and gateway daemon management
# arguments: "<platform> <action> [args...] | start | stop | status | logs"
# description: |
#   Daemon lifecycle + Discord messaging over the Kiln daemon's Unix socket RPC.
#   Use start/stop/status/logs for daemon management, or <platform> <action> for
#   messaging (send, read, voice, thread, channels, doc, subscribe).
# ---
#
# Daemon lifecycle:
#   gateway start                                     Start the kiln daemon
#   gateway stop                                      Stop the kiln daemon
#   gateway restart                                   Restart the kiln daemon
#   gateway status                                    Show daemon status
#   gateway logs [--limit N] [--follow]               Tail daemon logs
#   gateway ensure                                    Start if not running (for hooks)
#
# Messaging:
#   ⚠️  Messages with $ signs: use stdin to avoid shell expansion.
#      echo 'price is $10' | gateway discord post -
#
#   gateway discord send <target> <message|->         Send a message (@user or #channel)
#   gateway discord read <target> [--limit N]         Read channel history
#   gateway discord delete <channel> <message-id>     Delete a message by ID
#   gateway discord voice send <target> <text> [--voice V] [--tone "..."]
#                                                     Send voice message (TTS)
#   gateway discord channels                          List available channels
#
# Threads:
#   gateway discord thread create <channel> <name>    Create a thread
#   gateway discord thread archive <channel> <name>   Archive a thread
#
# Documents:
#   gateway discord doc <file> [--thread <name>]      Post a file to #docs
#
# Subscriptions:
#   gateway discord subscribe <surface-ref>           Subscribe to a surface
#   gateway discord unsubscribe <surface-ref>         Unsubscribe
#   gateway discord post <message|->                  Post to your branch thread
#

import asyncio
import json
import os
import signal
import subprocess
import sys
from pathlib import Path


# ---------------------------------------------------------------------------
# Daemon paths (shared with kiln.daemon.config)
# ---------------------------------------------------------------------------

KILN_ROOT = Path.home() / ".kiln"
DAEMON_DIR = KILN_ROOT / "daemon"
SOCKET_PATH = DAEMON_DIR / "kiln.sock"
PID_FILE = DAEMON_DIR / "kiln.pid"
LOG_FILE = DAEMON_DIR / "daemon.log"


# ---------------------------------------------------------------------------
# Session identity from environment
# ---------------------------------------------------------------------------

def get_session_id() -> str:
    return os.environ.get("KILN_AGENT_ID", "")


def get_agent_name() -> str:
    """Extract agent name (prefix) from session ID or env."""
    sid = get_session_id()
    if sid:
        return sid.split("-")[0]
    return os.environ.get("AGENT_PREFIX", "")


# ---------------------------------------------------------------------------
# Daemon client (lazy import — only when needed for RPC commands)
# ---------------------------------------------------------------------------

_client = None

def get_client():
    global _client
    if _client is not None:
        return _client

    try:
        from kiln.daemon.client import DaemonClient
    except ImportError:
        print("Error: Cannot import DaemonClient. Is kiln installed?", file=sys.stderr)
        sys.exit(2)

    agent = get_agent_name()
    session = get_session_id()
    if not agent or not session:
        print("Error: KILN_AGENT_ID not set. Run from within an agent session.", file=sys.stderr)
        sys.exit(2)

    _client = DaemonClient(agent=agent, session=session, auto_start=True)
    return _client


def run_async(coro):
    """Run an async coroutine, handling daemon errors cleanly."""
    try:
        return asyncio.run(coro)
    except KeyboardInterrupt:
        sys.exit(130)
    except Exception as e:
        # DaemonUnavailableError, DaemonError, etc
        name = type(e).__name__
        if "Daemon" in name:
            print(f"Error: {e}", file=sys.stderr)
            sys.exit(2)
        raise


# ---------------------------------------------------------------------------
# Lifecycle commands (delegate to kiln daemon process management)
# ---------------------------------------------------------------------------

def is_daemon_running() -> bool:
    if not PID_FILE.exists():
        return False
    try:
        pid = int(PID_FILE.read_text().strip())
        os.kill(pid, 0)
        return True
    except (ValueError, ProcessLookupError, PermissionError, OSError):
        return False


def cmd_start():
    if is_daemon_running():
        pid = PID_FILE.read_text().strip()
        print(f"Daemon already running (PID {pid})")
        return

    # Clean up stale files
    SOCKET_PATH.unlink(missing_ok=True)
    PID_FILE.unlink(missing_ok=True)
    DAEMON_DIR.mkdir(parents=True, exist_ok=True)

    subprocess.Popen(
        [sys.executable, "-m", "kiln.daemon.server", "--background"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )

    # Wait for socket
    import time
    for _ in range(50):
        if SOCKET_PATH.exists() and is_daemon_running():
            pid = PID_FILE.read_text().strip() if PID_FILE.exists() else "?"
            print(f"Daemon started (PID {pid})")
            return
        time.sleep(0.1)

    print(f"Error: Daemon failed to start. Check logs: {LOG_FILE}", file=sys.stderr)
    if LOG_FILE.exists():
        for line in LOG_FILE.read_text().splitlines()[-5:]:
            print(f"  {line}", file=sys.stderr)
    sys.exit(1)


def cmd_stop():
    if not PID_FILE.exists():
        print("Daemon not running")
        return

    try:
        pid = int(PID_FILE.read_text().strip())
        os.kill(pid, signal.SIGTERM)
        print(f"Sent SIGTERM to daemon (PID {pid})")
    except (ValueError, ProcessLookupError):
        print("Daemon not running (stale PID file)")
        PID_FILE.unlink(missing_ok=True)
        SOCKET_PATH.unlink(missing_ok=True)


def cmd_status():
    if not is_daemon_running():
        print("Daemon: not running")
        return

    pid = PID_FILE.read_text().strip() if PID_FILE.exists() else "?"
    print(f"Daemon: running (PID {pid})")
    print(f"Socket: {SOCKET_PATH}")

    async def _query():
        from kiln.daemon.client import DaemonClient, DaemonUnavailableError
        client = DaemonClient(agent="cli", session="cli-status", auto_start=False)
        try:
            status = await client.get_status()
            print(f"Sessions: {status.get('sessions', '?')}")
            print(f"Channels: {status.get('channels', '?')}")
            print(f"Bridges: {status.get('bridges', '?')}")
        except DaemonUnavailableError:
            print("(could not query daemon)")

    run_async(_query())


def cmd_logs(limit=50, follow=False):
    if not LOG_FILE.exists():
        print(f"No log file at {LOG_FILE}")
        return
    if follow:
        os.execvp("tail", ["tail", "-f", str(LOG_FILE)])
    else:
        os.execvp("tail", ["tail", f"-{limit}", str(LOG_FILE)])


def cmd_ensure():
    if is_daemon_running():
        return
    cmd_start()


# ---------------------------------------------------------------------------
# Content resolution (stdin for - arg)
# ---------------------------------------------------------------------------

def resolve_content(arg: str) -> str:
    if arg == "-":
        return sys.stdin.read()
    return arg


# ---------------------------------------------------------------------------
# Platform operation commands
# ---------------------------------------------------------------------------

def cmd_send(platform: str, target: str, content: str, thread: str | None = None):
    content = resolve_content(content)
    args = {"target": target, "content": content}
    if thread:
        args["thread"] = thread

    async def _run():
        client = get_client()
        result = await client.platform_op(platform, "send", args)
        if result.get("ok"):
            chunks = result.get("chunks", 1)
            print(f"Sent ({chunks} message{'s' if chunks != 1 else ''})")
        else:
            print(f"Error: {result.get('error', 'unknown')}", file=sys.stderr)
            sys.exit(1)

    run_async(_run())


def cmd_read(platform: str, target: str, limit: int = 20):
    async def _run():
        client = get_client()
        result = await client.platform_op(platform, "read_history", {
            "target": target, "limit": limit,
        })
        if not result.get("ok"):
            print(f"Error: {result.get('error', 'unknown')}", file=sys.stderr)
            sys.exit(1)
        for msg in result.get("messages", []):
            ts = msg.get("timestamp", "")[:19]
            author = msg.get("author", "?")
            text = msg.get("content", "")
            print(f"[{ts}] {author}: {text}")

    run_async(_run())


def cmd_delete(platform: str, target: str, message_id: str):
    async def _run():
        client = get_client()
        result = await client.platform_op(platform, "delete", {
            "target": target, "message_id": message_id,
        })
        if result.get("ok"):
            print("Deleted")
        else:
            print(f"Error: {result.get('error', 'unknown')}", file=sys.stderr)
            sys.exit(1)

    run_async(_run())


def cmd_voice_send(platform: str, target: str, text: str,
                   voice: str | None = None, tone: str | None = None):
    args = {"target": target, "text": text}
    if voice:
        args["voice"] = voice
    if tone:
        args["instructions"] = tone

    async def _run():
        client = get_client()
        result = await client.platform_op(platform, "voice_send", args)
        if result.get("ok"):
            print("Voice message sent")
        else:
            print(f"Error: {result.get('error', 'unknown')}", file=sys.stderr)
            sys.exit(1)

    run_async(_run())


def cmd_thread_create(platform: str, channel: str, name: str):
    async def _run():
        client = get_client()
        result = await client.platform_op(platform, "thread_create", {
            "channel": channel, "name": name,
        })
        if result.get("ok"):
            print(f"Thread '{name}' created (id: {result.get('thread_id', '?')})")
        else:
            print(f"Error: {result.get('error', 'unknown')}", file=sys.stderr)
            sys.exit(1)

    run_async(_run())


def cmd_thread_archive(platform: str, channel: str, name: str):
    async def _run():
        client = get_client()
        result = await client.platform_op(platform, "thread_archive", {
            "channel": channel, "name": name,
        })
        if result.get("ok"):
            print(f"Thread '{name}' archived")
        else:
            print(f"Error: {result.get('error', 'unknown')}", file=sys.stderr)
            sys.exit(1)

    run_async(_run())


def cmd_channels(platform: str):
    async def _run():
        client = get_client()
        result = await client.platform_op(platform, "list_channels", {})
        if not result.get("ok"):
            print(f"Error: {result.get('error', 'unknown')}", file=sys.stderr)
            sys.exit(1)
        for ch in result.get("channels", []):
            cat = ch.get("category", "")
            prefix = f"[{cat}] " if cat else ""
            print(f"  {prefix}#{ch['name']}  ({ch['id']})")

    run_async(_run())


def cmd_post(platform: str, content: str):
    content = resolve_content(content)
    session = get_session_id()
    if not session:
        print("Error: KILN_AGENT_ID not set.", file=sys.stderr)
        sys.exit(2)

    async def _run():
        client = get_client()
        result = await client.platform_op(platform, "branch_post", {
            "session_id": session, "content": content,
        })
        if result.get("ok"):
            print("Posted to branch thread")
        else:
            print(f"Error: {result.get('error', 'unknown')}", file=sys.stderr)
            sys.exit(1)

    run_async(_run())


def cmd_doc(platform: str, file_path: str, thread_name: str | None = None):
    path = Path(file_path)
    if not path.exists():
        print(f"Error: file not found: {file_path}", file=sys.stderr)
        sys.exit(1)

    content = path.read_text()
    if not content.strip():
        print(f"Error: file is empty: {file_path}", file=sys.stderr)
        sys.exit(1)

    if not thread_name:
        thread_name = path.stem

    async def _run():
        client = get_client()
        result = await client.platform_op(platform, "send", {
            "target": "#docs",
            "content": content,
            "thread": thread_name,
        })
        if result.get("ok"):
            chunks = result.get("chunks", 1)
            print(f"Posted {path.name} to #docs thread \"{thread_name}\" ({chunks} message(s))")
        else:
            print(f"Error: {result.get('error', 'unknown')}", file=sys.stderr)
            sys.exit(1)

    run_async(_run())


def cmd_subscribe(platform: str, surface_ref: str):
    async def _run():
        client = get_client()
        count = await client.subscribe_surface(surface_ref)
        print(f"Subscribed to {surface_ref} ({count} subscriber(s))")

    run_async(_run())


def cmd_unsubscribe(platform: str, surface_ref: str):
    async def _run():
        client = get_client()
        await client.unsubscribe_surface(surface_ref)
        print(f"Unsubscribed from {surface_ref}")

    run_async(_run())


# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

USAGE = """\
Usage: gateway <command> [args...]

Daemon lifecycle:
  start                                     Start the kiln daemon
  stop                                      Stop the kiln daemon
  restart                                   Restart the kiln daemon
  status                                    Show daemon status
  logs [--limit N] [--follow]               Tail daemon logs
  ensure                                    Start if not running (for hooks)

Messaging:
  <platform> send <target> <message>        Send a message
  <platform> post <message>                 Post to your branch thread
  <platform> read <target> [--limit N]      Read channel history
  <platform> delete <channel> <msg-id>      Delete a message
  <platform> voice send <target> <text>     Send voice message (TTS)
  <platform> doc <file> [--thread <name>]   Post a file to #docs
  <platform> thread create <channel> <name> Create a thread
  <platform> thread archive <channel> <name> Archive a thread
  <platform> channels                       List available channels
  <platform> subscribe <surface-ref>        Subscribe to a surface
  <platform> unsubscribe <surface-ref>      Unsubscribe from a surface

Examples:
  gateway start
  gateway discord send "#general" "hello world"
  gateway discord send "@kira" "DM content"
  gateway discord read "#general" --limit 10
  gateway discord channels
  echo 'price is $10' | gateway discord post -
"""


# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

def main():
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help", "help"):
        print(USAGE)
        sys.exit(0)

    cmd = args[0]

    # --- Lifecycle commands ---
    if cmd == "start":
        cmd_start()
    elif cmd == "stop":
        cmd_stop()
    elif cmd == "restart":
        cmd_stop()
        import time; time.sleep(1)
        cmd_start()
    elif cmd == "status":
        cmd_status()
    elif cmd == "logs":
        limit, follow = 50, False
        i = 1
        while i < len(args):
            if args[i] == "--limit" and i + 1 < len(args):
                limit = int(args[i + 1]); i += 2
            elif args[i] in ("--follow", "-f"):
                follow = True; i += 1
            else:
                i += 1
        cmd_logs(limit, follow)
    elif cmd == "ensure":
        cmd_ensure()
    else:
        # --- Platform commands: gateway <platform> <action> [args...] ---
        platform = cmd
        if len(args) < 2:
            print(f"Error: missing action for platform '{platform}'", file=sys.stderr)
            print(USAGE, file=sys.stderr)
            sys.exit(1)

        action = args[1]
        rest = args[2:]

        # Parse --flags from remaining args
        positional = []
        flags = {}
        i = 0
        while i < len(rest):
            if rest[i] == "--limit" and i + 1 < len(rest):
                flags["limit"] = int(rest[i + 1]); i += 2
            elif rest[i] == "--thread" and i + 1 < len(rest):
                flags["thread"] = rest[i + 1]; i += 2
            elif rest[i] == "--voice" and i + 1 < len(rest):
                flags["voice"] = rest[i + 1]; i += 2
            elif rest[i] == "--tone" and i + 1 < len(rest):
                flags["tone"] = rest[i + 1]; i += 2
            elif rest[i] in ("--follow", "-f"):
                flags["follow"] = True; i += 1
            else:
                positional.append(rest[i]); i += 1

        # --- Dispatch platform actions ---
        if action == "send":
            if len(positional) < 2:
                print(f"Usage: gateway {platform} send <target> <message>", file=sys.stderr)
                sys.exit(1)
            cmd_send(platform, positional[0], positional[1], flags.get("thread"))

        elif action == "post":
            if len(positional) < 1:
                print(f"Usage: gateway {platform} post <message>", file=sys.stderr)
                sys.exit(1)
            cmd_post(platform, positional[0])

        elif action == "read":
            if len(positional) < 1:
                print(f"Usage: gateway {platform} read <target> [--limit N]", file=sys.stderr)
                sys.exit(1)
            cmd_read(platform, positional[0], flags.get("limit", 20))

        elif action == "delete":
            if len(positional) < 2:
                print(f"Usage: gateway {platform} delete <channel> <message-id>", file=sys.stderr)
                sys.exit(1)
            cmd_delete(platform, positional[0], positional[1])

        elif action == "voice":
            if not positional or positional[0] != "send" or len(positional) < 3:
                print(f"Usage: gateway {platform} voice send <target> <text> [--voice V] [--tone ...]",
                      file=sys.stderr)
                sys.exit(1)
            cmd_voice_send(platform, positional[1], positional[2],
                           flags.get("voice"), flags.get("tone"))

        elif action == "thread":
            if not positional:
                print(f"Usage: gateway {platform} thread <create|archive> <channel> <name>",
                      file=sys.stderr)
                sys.exit(1)
            sub = positional[0]
            if sub == "create" and len(positional) >= 3:
                cmd_thread_create(platform, positional[1], positional[2])
            elif sub == "archive" and len(positional) >= 3:
                cmd_thread_archive(platform, positional[1], positional[2])
            else:
                print(f"Usage: gateway {platform} thread <create|archive> <channel> <name>",
                      file=sys.stderr)
                sys.exit(1)

        elif action == "doc":
            if len(positional) < 1:
                print(f"Usage: gateway {platform} doc <file> [--thread <name>]", file=sys.stderr)
                sys.exit(1)
            cmd_doc(platform, positional[0], flags.get("thread"))

        elif action == "channels":
            cmd_channels(platform)

        elif action == "subscribe":
            if len(positional) < 1:
                print(f"Usage: gateway {platform} subscribe <surface-ref>", file=sys.stderr)
                sys.exit(1)
            cmd_subscribe(platform, positional[0])

        elif action == "unsubscribe":
            if len(positional) < 1:
                print(f"Usage: gateway {platform} unsubscribe <surface-ref>", file=sys.stderr)
                sys.exit(1)
            cmd_unsubscribe(platform, positional[0])

        else:
            print(f"Unknown action: {action}", file=sys.stderr)
            print(USAGE, file=sys.stderr)
            sys.exit(1)


if __name__ == "__main__":
    main()
