# ---- find ------------------------------------------------------------------

def _run_hybrid_find(
    con: sqlite3.Connection, query: str, *, sparse: bool,
    pool: int, k: int, w_summary: float, w_conv: float,
    aggregation: str, since: str | None, until: str | None,
) -> tuple[list[Hit], SummaryLane, bool]:
    """Core retrieval. Returns (hits, summary_lane_info, semantic_ran)."""
    sum_lane = search_summaries(con, query, pool, since=since, until=until)

    semantic_hits: list[SemanticHit] = []
    semantic_ran = False
    if not sparse:
        api_key = _load_openai_key()
        have_semantic = (
            api_key is not None
            and con.execute(
                "SELECT COUNT(*) FROM chunk_embeddings WHERE model=?", (EMBED_MODEL,)
            ).fetchone()[0] > 0
        )
        if have_semantic:
            try:
                qv = embed_many(api_key, [query])
                semantic_hits = search_semantic(
                    con, qv[0], pool,
                    aggregation=aggregation, since=since, until=until,
                )
                semantic_ran = True
            except Exception as e:
                print(f"[!] Embedding query failed ({e}) — degrading to summary-only.",
                      file=sys.stderr)
        elif api_key is None:
            print("[!] No OPENAI_API_KEY — degrading to summary-only "
                  "(semantic lane disabled). Pass --sparse to silence.",
                  file=sys.stderr)
        else:
            print("[!] No chunk embeddings in index — degrading to summary-only. "
                  "Run 'recall reindex --embed-only', or pass --sparse to silence.",
                  file=sys.stderr)

    meta_by_key: dict[str, tuple[str, str, str]] = {}
    keys_needed = {h.session_key for h in semantic_hits} - {s[0] for s in sum_lane.hits}
    if keys_needed:
        placeholders = ",".join("?" * len(keys_needed))
        rows = con.execute(
            f"SELECT session_key, date, agent_id, title FROM summaries "
            f"WHERE session_key IN ({placeholders})",
            tuple(keys_needed),
        ).fetchall()
        for skey, date, agent, title in rows:
            meta_by_key[skey] = (date, agent, title or "")

    hits = rrf_merge(
        sum_lane.hits, semantic_hits,
        k=k, w_summary=w_summary, w_conv=w_conv,
        meta_by_key=meta_by_key,
    )
    return hits, sum_lane, semantic_ran


def cmd_find(args: argparse.Namespace) -> int:
    con = open_db()
    ensure_indexed(con)

    hits, sum_lane, _ = _run_hybrid_find(
        con, args.query,
        sparse=args.sparse,
        pool=args.pool,
        k=args.k,
        w_summary=args.w_summary,
        w_conv=args.w_conv,
        aggregation=args.aggregation,
        since=args.since,
        until=args.until,
    )

    if sum_lane.relaxed_to_or:
        print("[!] Broadened to OR matching — no results for strict AND.",
              file=sys.stderr)

    if not hits:
        print("No matches.")
        return 1

    # --sort date: re-order the candidate pool by date DESC before truncation.
    if args.sort == "date":
        hits = sorted(hits, key=lambda h: (h.date, h.session_key), reverse=True)
    hits = hits[:args.n]

    print(format_hits(con, hits, args.query, why=args.why, passages=args.passages))
    return 0


# ---- dig -------------------------------------------------------------------

@dataclass
class DigHit:
    chunk_id: int | None   # None for on-the-fly --deep chunks
    turn_start: int
    turn_end: int
    score: float
    text: str


def _dig_indexed(
    con: sqlite3.Connection, session_key: str, query_vec: list[float], n: int,
) -> list[DigHit]:
    rows = con.execute(
        "SELECT c.id, c.turn_start, c.turn_end, c.text, e.vector "
        "FROM chunks c JOIN chunk_embeddings e "
        "  ON e.chunk_id = c.id AND e.model = ? "
        "WHERE c.session_key = ? "
        "ORDER BY c.chunk_idx ASC",
        (EMBED_MODEL, session_key),
    ).fetchall()
    if not rows:
        return []
    scored = []
    for cid, tstart, tend, text, vec_blob in rows:
        vec = _unpack_vec(vec_blob)
        scored.append(DigHit(cid, tstart, tend, _cos(query_vec, vec), text))
    scored.sort(key=lambda h: h.score, reverse=True)
    return scored[:n]


def _dig_deep(
    jsonl_path: Path, query_vec: list[float], api_key: str, n: int,
) -> list[DigHit]:
    turns = list(iter_conversation_turns(jsonl_path))
    chunks = chunk_turns(turns)
    if not chunks:
        return []
    texts = [c[0] for c in chunks]
    vectors = embed_many(api_key, texts, progress=False)
    scored = []
    for (text, tstart, tend), vec in zip(chunks, vectors):
        scored.append(DigHit(None, tstart, tend, _cos(query_vec, vec), text))
    scored.sort(key=lambda h: h.score, reverse=True)
    return scored[:n]


def cmd_dig(args: argparse.Namespace) -> int:
    con = open_db()
    ensure_indexed(con)

    skey = resolve_session_key(con, args.session)
    if not skey:
        return 1

    api_key = _load_openai_key()
    if not api_key:
        print("[!] dig requires OPENAI_API_KEY for semantic scoring.", file=sys.stderr)
        return 2

    try:
        qv = embed_many(api_key, [args.query])[0]
    except Exception as e:
        print(f"[!] Embedding query failed: {e}", file=sys.stderr)
        return 2

    hits: list[DigHit] = []
    if not args.deep:
        hits = _dig_indexed(con, skey, qv, args.n)
        if not hits:
            print(f"No indexed chunks for {skey}. Pass --deep to scan the raw JSONL.",
                  file=sys.stderr)
            return 1
    else:
        jsonl = _resolve_jsonl(con, skey)
        if jsonl is None:
            print(f"No JSONL found for {skey} — cannot --deep.", file=sys.stderr)
            return 1
        print(f"[recall] --deep: chunking + embedding {jsonl.name} on the fly…",
              file=sys.stderr)
        hits = _dig_deep(jsonl, qv, api_key, args.n)
        if not hits:
            print(f"No content in JSONL for {skey}.", file=sys.stderr)
            return 1

    print(f"# {skey}")
    print()
    for i, h in enumerate(hits, 1):
        if h.turn_start == h.turn_end:
            tref = f"turn ~{h.turn_start}"
        else:
            tref = f"turns {h.turn_start}-{h.turn_end}"
        print(f"[{i}] {tref}  score {h.score:.3f}")
        for line in h.text.splitlines():
            print(f"  {line}")
        print()
    return 0


# ---- ask -------------------------------------------------------------------

ASK_SYSTEM_PROMPT = """You answer questions by synthesizing retrieved excerpts \
from past AI-agent sessions. Your rules:

1. Use ONLY the retrieved excerpts below. Do not draw on prior knowledge.
2. Cite every claim inline with the session key in brackets, e.g. \
[beth-gold-dale]. A paragraph with no citation is a bug — add one or drop the \
paragraph.
3. If the excerpts are thin, conflicting, or don't cover the question, say so \
explicitly. Do not hallucinate to fill gaps.
4. Stay grounded in what the excerpts actually say. Quote short phrases when \
useful."""


def _build_ask_excerpts(
    con: sqlite3.Connection, hits: list[Hit], passages: int,
) -> tuple[str, dict[str, tuple[str, str]]]:
    """Return (excerpt_block, cited_meta) where cited_meta[key] = (date, title)."""
    lines = []
    meta: dict[str, tuple[str, str]] = {}
    for h in hits:
        title = h.title or "(no title)"
        meta[h.session_key] = (h.date, title)
        lines.append(f"[{h.session_key}] {h.date} — {title}")
        row = con.execute(
            "SELECT summary_text FROM summaries WHERE session_key=?",
            (h.session_key,),
        ).fetchone()
        if row and row[0]:
            body = row[0]
            parts = [p.strip() for p in body.split("\n\n")
                     if p.strip() and not p.strip().startswith("#")]
            if parts:
                lines.append(f"  [summary] {parts[0][:600]}")
        shown = 0
        for cid, score in h.top_chunks[:passages]:
            text = _chunk_text(con, cid)
            if not text:
                continue
            shown += 1
            if len(text) > 800:
                text = text[:800] + "…"
            lines.append(f"  [conv cos={score:.2f}]")
            for ln in text.splitlines():
                lines.append(f"    {ln}")
        lines.append("")
    return "\n".join(lines), meta


def _build_ask_prompt(query: str, excerpts: str) -> str:
    return (
        ASK_SYSTEM_PROMPT
        + "\n\n---\n\nQuestion: " + query
        + "\n\n---\n\nExcerpts:\n" + excerpts
        + "\nAnswer (cite inline with [session-key] tags):"
    )


# Match bracketed session keys: either `beth-foo-bar` style or
# `YYYY-MM-DD-beth-foo-bar[_N]` style.
_CITE_RE = re.compile(
    r"\[(?P<key>(?:\d{4}-\d{2}-\d{2}-)?[a-z]+-[a-z0-9]+-[a-z0-9]+(?:_\d+)?)\]"
)


def _parse_cites(text: str) -> list[str]:
    return [m.group("key") for m in _CITE_RE.finditer(text)]


def _call_claude(prompt: str) -> tuple[str, str]:
    """Invoke claude -p via subprocess. Returns (stdout, stderr).

    stdin=DEVNULL is the canonical fix for the CC-session stdio-hang bug —
    bare `claude -p` inside CC inherits the SDK command pipe and blocks.
    """
    env = {k: v for k, v in os.environ.items() if k != "CLAUDECODE"}
    result = subprocess.run(
        ["claude", "-p", prompt,
         "--model", SYNTH_MODEL,
         "--allowedTools", "",
         "--no-session-persistence"],
        stdin=subprocess.DEVNULL,
        capture_output=True,
        text=True,
        env=env,
        timeout=SYNTH_TIMEOUT_S,
    )
    if result.returncode != 0:
        raise RuntimeError(f"claude -p exit {result.returncode}: {result.stderr.strip()}")
    return result.stdout.strip(), result.stderr


def cmd_ask(args: argparse.Namespace) -> int:
    con = open_db()
    ensure_indexed(con)

    # --- Retrieval ---
    if args.session:
        skey = resolve_session_key(con, args.session)
        if not skey:
            return 1
        api_key = _load_openai_key()
        if not api_key:
            print("[!] ask --session requires OPENAI_API_KEY for retrieval.",
                  file=sys.stderr)
            return 2
        try:
            qv = embed_many(api_key, [args.query])[0]
        except Exception as e:
            print(f"[!] Embedding query failed: {e}", file=sys.stderr)
            return 2
        dig_hits = _dig_indexed(con, skey, qv, 5)
        if not dig_hits:
            print(f"No indexed chunks for {skey}.", file=sys.stderr)
            return 1
        row = con.execute(
            "SELECT date, agent_id, title FROM summaries WHERE session_key=?",
            (skey,),
        ).fetchone()
        if not row:
            print(f"[!] No summary row for {skey}.", file=sys.stderr)
            return 1
        date, agent, title = row
        hits = [Hit(
            session_key=skey,
            rrf_score=0.0,
            date=date,
            agent_id=agent,
            title=title or "",
            summary_rank=1,
            conv_rank=1,
            conv_chunk_id=dig_hits[0].chunk_id,
            conv_best_score=dig_hits[0].score,
            bm25_score=None,
            top_chunks=[(h.chunk_id, h.score) for h in dig_hits if h.chunk_id is not None],
        )]
    else:
        hits, sum_lane, _ = _run_hybrid_find(
            con, args.query,
            sparse=False,
            pool=DEFAULT_POOL,
            k=DEFAULT_K,
            w_summary=DEFAULT_W_SUMMARY,
            w_conv=DEFAULT_W_CONV,
            aggregation=DEFAULT_AGG,
            since=None, until=None,
        )
        if sum_lane.relaxed_to_or:
            print("[!] Broadened to OR matching.", file=sys.stderr)
        hits = hits[:args.sessions]
        if not hits:
            print("No sessions matched — nothing to synthesize from.",
                  file=sys.stderr)
            return 1

    excerpts, cited_meta = _build_ask_excerpts(con, hits, passages=3)
    prompt = _build_ask_prompt(args.query, excerpts)

    print(f"[recall] Synthesizing via {SYNTH_MODEL}…", file=sys.stderr, flush=True)
    t0 = time.time()
    try:
        answer, _ = _call_claude(prompt)
    except subprocess.TimeoutExpired:
        print("[!] Synthesis timed out. Retrieved excerpts below.", file=sys.stderr)
        _dump_raw_hits(con, hits, args.query)
        return 2
    except Exception as e:
        print(f"[!] Synthesis failed ({e}) — showing retrieved excerpts.",
              file=sys.stderr)
        _dump_raw_hits(con, hits, args.query)
        return 2
    print(f"[recall]   done in {time.time()-t0:.1f}s", file=sys.stderr)

    cited = _parse_cites(answer)
    if not cited:
        print("[!] Synthesis returned no citations — the model didn't cite. "
              "Raw answer shown anyway.", file=sys.stderr)
    print("### Answer\n")
    print(answer)
    print()
    print("### Citations\n")
    ordered = []
    seen = set()
    for key in cited:
        if key not in seen and key in cited_meta:
            ordered.append(key)
            seen.add(key)
    if not ordered:
        ordered = [h.session_key for h in hits]
    for key in ordered:
        date, title = cited_meta.get(key, ("?", "?"))
        print(f"[{key}] {date} — {title}")
        hit = next((h for h in hits if h.session_key == key), None)
        if hit and hit.top_chunks:
            cid = hit.top_chunks[0][0]
            txt = _chunk_text(con, cid)
            if txt:
                snip = _snippet(txt, args.query, 240)
                print(f"  {snip}")
        print()
    return 0


def _dump_raw_hits(con: sqlite3.Connection, hits: list[Hit], query: str) -> None:
    print(format_hits(con, hits, query, why=False, passages=1))


