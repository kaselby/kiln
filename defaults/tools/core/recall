# Stopwords dropped from queries with >2 terms (common interrogatives + filler).
# If post-strip term count drops below 2, we abandon the strip — a low-signal
# query should show nothing-matched rather than everything-matched.
STOPWORDS = frozenset({
    "how", "why", "what", "when", "where", "who", "which",
    "about", "did", "do", "does", "is", "was", "were", "are", "be",
    "we", "i", "it", "that", "this", "those", "these",
