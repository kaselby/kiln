GLOB_CHARS = set("*?[")


def _pattern_predicate(pattern: str) -> tuple[str, str]:
    """Decide matching mode. Returns (mode, normalized_pattern).

    mode: 'glob' | 'substring'.
    """
    if any(c in pattern for c in GLOB_CHARS):
        return "glob", pattern
    return "substring", pattern.lower()


def _match_path(mode: str, pattern: str, path: str) -> bool:
    if mode == "glob":
        # fnmatch matches the whole string. For convenience, also allow
        # tail-matches so `daemon/*.py` matches `.../daemon/foo.py`.
        if fnmatch.fnmatchcase(path, pattern):
            return True
        parts = path.split("/")
        for i in range(len(parts)):
            tail = "/".join(parts[i:])
            if fnmatch.fnmatchcase(tail, pattern):
                return True
        return False
    return pattern in path.lower()


def cmd_files(args: argparse.Namespace) -> int:
    con = open_db()
    ensure_indexed(con)

    sql = "SELECT session_key FROM summaries"
    params: list = []
    where = []
    if args.since:
        where.append("date >= ?"); params.append(args.since)
    if args.until:
        where.append("date <= ?"); params.append(args.until)
    if where:
        sql += " WHERE " + " AND ".join(where)
    candidate_keys = [r[0] for r in con.execute(sql, params)]

    _ensure_files_indexed(con, candidate_keys, progress=True)

    mode, norm = _pattern_predicate(args.pattern)

    sql = (
        "SELECT sf.session_key, sf.file_path, s.date, s.agent_id "
        "FROM session_files sf JOIN summaries s ON s.session_key = sf.session_key"
    )
    params2: list = []
    where2 = []
    if args.since:
        where2.append("s.date >= ?"); params2.append(args.since)
    if args.until:
        where2.append("s.date <= ?"); params2.append(args.until)
    if where2:
        sql += " WHERE " + " AND ".join(where2)
    rows = con.execute(sql, params2).fetchall()

    per_session: dict[str, tuple[str, str, list[str]]] = {}
    for skey, fp, date, agent in rows:
        if _match_path(mode, norm, fp):
            entry = per_session.setdefault(skey, (date, agent, []))
            entry[2].append(fp)

    if not per_session:
        print(f"No sessions touched a path matching '{args.pattern}'.")
        return 1

    # Rank: match count DESC, then date DESC.
    ordered = sorted(
        per_session.items(),
        key=lambda kv: (len(kv[1][2]), kv[1][0]),
        reverse=True,
    )

    for skey, (date, agent, paths) in ordered[:args.n]:
        paths_sorted = sorted(paths)
        nmatches = len(paths_sorted)
        plural = "matches" if nmatches != 1 else "match"
        print(f"{date} {agent:<24s}  {nmatches} {plural}")
        head = paths_sorted[:10]
        for p in head:
            print(f"  {p}")
        if nmatches > len(head):
            print(f"  ...and {nmatches - len(head)} more")
        print()
    return 0


