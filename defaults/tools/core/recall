def cmd_show(args: argparse.Namespace) -> int:
    con = open_db()
    ensure_indexed(con)

    skey = resolve_session_key(con, args.session)
    if not skey:
        return 1

    row = con.execute(
        "SELECT date, agent_id, title, path, summary_text FROM summaries WHERE session_key=?",
        (skey,),
    ).fetchone()
    if not row:
        print(f"No summary row for {skey}.", file=sys.stderr)
        return 1
    date, agent, title, path, body = row
    print(f"Session:  {skey}")
    print(f"Date:     {date}")
    print(f"Agent:    {agent}")
    print(f"Title:    {title or '(no title)'}")
    print(f"Summary:  {path}")
    print()
    print(body)

    cv = con.execute(
        "SELECT COUNT(*), COALESCE(SUM(token_count),0), MAX(source_path), MAX(source) "
        "FROM chunks WHERE session_key=?",
        (skey,),
    ).fetchone()
    if cv and cv[0]:
        print()
        print(f"Conversation: {cv[0]} chunks / ~{cv[1]} tokens")
        print(f"              source={cv[3]} path={cv[2]}")

    _ensure_files_indexed(con, [skey], progress=True)
    frows = con.execute(
        "SELECT file_path FROM session_files WHERE session_key=? ORDER BY file_path",
        (skey,),
    ).fetchall()
    print()
    print(f"Files touched: {len(frows)}")
    for (fp,) in frows[:10]:
        print(f"  {fp}")
    if len(frows) > 10:
        print(f"  ...and {len(frows) - 10} more")
    return 0


