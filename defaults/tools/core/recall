def cmd_reindex(args: argparse.Namespace) -> int:
    con = open_db()
    t0_total = time.time()

    if args.files_only:
        keys = _all_session_keys(con)
        if args.force:
            con.execute("DELETE FROM files_indexed")
            con.execute("DELETE FROM session_files")
            con.commit()
        n = _ensure_files_indexed(con, keys, progress=True)
        print(f"Files: backfilled {n} sessions ({time.time()-t0_total:.1f}s)",
              file=sys.stderr)
        return 0

    if not args.embed_only:
        t0 = time.time()
        added, skipped = _reindex_summaries(con, force=args.force)
        print(f"Summaries: {added} indexed, {skipped} unchanged ({time.time()-t0:.1f}s)",
              file=sys.stderr)

    if not args.summaries_only:
        if not args.embed_only:
            t0 = time.time()
            added_f, skipped_f = _reindex_conversations(con, force=args.force)
            print(f"Conversations: {added_f} files indexed, {skipped_f} unchanged "
                  f"({time.time()-t0:.1f}s)", file=sys.stderr)
        api_key = _load_openai_key()
        if not api_key:
            print("[!] No OPENAI_API_KEY — skipping embedding. Semantic lane disabled.",
                  file=sys.stderr)
        else:
            t0 = time.time()
            n = embed_missing_chunks(con, api_key, progress=True)
            print(f"Embeddings: {n} embedded ({time.time()-t0:.1f}s)", file=sys.stderr)

    print(f"Total: {time.time()-t0_total:.1f}s", file=sys.stderr)
    return 0


# ---- stats -----------------------------------------------------------------

def cmd_stats(args: argparse.Namespace) -> int:
    con = open_db()
    nsum = con.execute("SELECT COUNT(*) FROM summaries").fetchone()[0]
    sum_tokens = con.execute(
        "SELECT COALESCE(SUM(LENGTH(summary_text)),0)/4 FROM summaries"
    ).fetchone()[0]
    nchunks = con.execute("SELECT COUNT(*) FROM chunks").fetchone()[0]
    nemb = con.execute(
        "SELECT COUNT(*) FROM chunk_embeddings WHERE model=?", (EMBED_MODEL,)
    ).fetchone()[0]
    nsessions_conv = con.execute(
        "SELECT COUNT(DISTINCT session_key) FROM chunks"
    ).fetchone()[0]
    nfiles = con.execute("SELECT COUNT(*) FROM session_files").fetchone()[0]
    nfiles_sessions = con.execute("SELECT COUNT(*) FROM files_indexed").fetchone()[0]
    avg_chunks = (nchunks / nsessions_conv) if nsessions_conv else 0
    db_bytes = INDEX_DB.stat().st_size if INDEX_DB.exists() else 0
    last_indexed = con.execute("SELECT MAX(mtime) FROM summaries").fetchone()[0]
    last_str = ""
    if last_indexed:
        last_str = time.strftime("%Y-%m-%d %H:%M:%S", time.localtime(last_indexed))

    print(f"Index:            {INDEX_DB}")
    print(f"Summaries:        {nsum} (~{sum_tokens} tokens total)")
    print(f"Conv chunks:      {nchunks} across {nsessions_conv} sessions "
          f"(avg {avg_chunks:.1f})")
    print(f"Embeddings:       {nemb}/{nchunks} "
          f"({100*nemb/nchunks if nchunks else 0:.1f}%) [{EMBED_MODEL}]")
    print(f"Files indexed:    {nfiles} paths across {nfiles_sessions} sessions")
    print(f"DB size:          {db_bytes/1024/1024:.1f} MB")
    print(f"Last indexed:     {last_str}")

    covered = con.execute(
        "SELECT COUNT(DISTINCT s.session_key) FROM summaries s "
        "WHERE EXISTS (SELECT 1 FROM chunks c WHERE c.session_key = s.session_key)"
    ).fetchone()[0]
    print(f"Cross-covered:    {covered} sessions have both summary + conversation")
    print(f"Summary-only:     {nsum - covered}")
    conv_only = con.execute(
        "SELECT COUNT(DISTINCT c.session_key) FROM chunks c "
        "WHERE NOT EXISTS (SELECT 1 FROM summaries s WHERE s.session_key = c.session_key)"
    ).fetchone()[0]
    print(f"Conversation-only:{conv_only}")
    return 0


# ---- Arg parsing -----------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="recall",
        description="Session recall: find, dig, ask, files, show, list, reindex, stats.",
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    pf = sub.add_parser("find", help="Ranked session lookup (hybrid by default).")
    pf.add_argument("query", nargs="+")
    pf.add_argument("-n", type=int, default=10, help="results to show (default 10)")
    pf.add_argument("--sparse", action="store_true",
                    help="BM25 summaries only — bypass semantic lane. Best for "
                         "commit hashes, agent-ids, task refs.")
    pf.add_argument("--passages", type=int, default=1,
                    help="passages per result (default 1)")
    pf.add_argument("--why", action="store_true", help="show per-lane scores")
    pf.add_argument("--since", help="date lower bound YYYY-MM-DD")
    pf.add_argument("--until", help="date upper bound YYYY-MM-DD")
    pf.add_argument("--sort", choices=("relevance", "date"), default="relevance",
                    help="sort order (default relevance)")
    pf.add_argument("-k", type=int, default=DEFAULT_K, help="RRF k constant")
    pf.add_argument("--w-summary", type=float, default=DEFAULT_W_SUMMARY,
                    help="lane 1 weight")
    pf.add_argument("--w-conv", type=float, default=DEFAULT_W_CONV,
                    help="lane 2 weight")
    pf.add_argument("--pool", type=int, default=DEFAULT_POOL,
                    help="candidate pool size per lane")
    pf.add_argument("--aggregation", choices=("max", "top3mean"),
                    default=DEFAULT_AGG, help="session-level chunk aggregation")
    pf.set_defaults(func=cmd_find)

    pd = sub.add_parser("dig",
                        help="Top-N passages from a specific session (query required).")
    pd.add_argument("session", help="session key, full or fuzzy agent-id")
    pd.add_argument("query", nargs="+")
    pd.add_argument("-n", type=int, default=5, help="passages to show (default 5)")
    pd.add_argument("--deep", action="store_true",
                    help="scan the raw JSONL on the fly (slow; use when indexed "
                         "chunks are thin)")
    pd.set_defaults(func=cmd_dig)

    pa = sub.add_parser("ask",
                        help="Synthesized answer via Haiku with forced citations.")
    pa.add_argument("query", nargs="+")
    pa.add_argument("--session", help="scope synthesis to one session")
    pa.add_argument("--sessions", type=int, default=8,
                    help="breadth of context (default 8)")
    pa.set_defaults(func=cmd_ask)

    pfi = sub.add_parser("files", help="Cross-session file-touch lookup.")
    pfi.add_argument("pattern",
                     help="substring, or glob if it contains * ? [")
    pfi.add_argument("-n", type=int, default=20, help="max sessions (default 20)")
    pfi.add_argument("--since")
    pfi.add_argument("--until")
    pfi.set_defaults(func=cmd_files)

    ps = sub.add_parser("show", help="Summary + metadata + files-touched.")
    ps.add_argument("session")
    ps.set_defaults(func=cmd_show)

    pl = sub.add_parser("list", help="Recent sessions, one per line.")
    pl.add_argument("-n", type=int, default=20)
    pl.add_argument("--since")
    pl.set_defaults(func=cmd_list)

    pr = sub.add_parser("reindex", help="Rebuild / refresh index.")
    g = pr.add_mutually_exclusive_group()
    g.add_argument("--force", action="store_true",
                   help="rebuild everything from scratch")
    g.add_argument("--embed-only", action="store_true",
                   help="only fill missing embeddings")
    g.add_argument("--summaries-only", action="store_true",
                   help="only update FTS5 summaries")
    g.add_argument("--files-only", action="store_true",
                   help="only (re)populate the file-touch index")
    pr.set_defaults(func=cmd_reindex)

    pt = sub.add_parser("stats", help="Index health.")
    pt.set_defaults(func=cmd_stats)

    return p


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    if args.cmd in ("find", "ask", "dig"):
        args.query = " ".join(args.query)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
