def open_db() -> sqlite3.Connection:
    INDEX_DB.parent.mkdir(parents=True, exist_ok=True)
    con = sqlite3.connect(INDEX_DB)
    con.executescript(SCHEMA)
    con.execute("PRAGMA foreign_keys = ON")
    return con


def _has_any_summaries(con: sqlite3.Connection) -> bool:
    return con.execute("SELECT COUNT(*) FROM summaries").fetchone()[0] > 0


def ensure_indexed(con: sqlite3.Connection) -> None:
    """Auto-index on first use if the DB is empty."""
    if _has_any_summaries(con):
        return
    print(f"[recall] First run — building index at {INDEX_DB}", file=sys.stderr)
    print("[recall] This takes ~2 minutes the first time. Future queries are fast.",
          file=sys.stderr)
    _reindex_summaries(con)
    _reindex_conversations(con)
    api_key = _load_openai_key()
    if api_key:
        n = embed_missing_chunks(con, api_key, progress=True)
        print(f"[recall]   embeddings: {n} embedded", file=sys.stderr)
    else:
        print("[recall]   [!] No OPENAI_API_KEY — semantic lane disabled. Run "
              "'recall reindex --embed-only' later to fill.", file=sys.stderr)


# ---- Indexing: summaries ---------------------------------------------------

def _reindex_summaries(con: sqlite3.Connection, *, force: bool = False) -> tuple[int, int]:
    if not SUMMARIES_DIR.exists():
        return 0, 0
    existing: dict[str, float] = {
        row[0]: row[1]
        for row in con.execute("SELECT session_key, mtime FROM summaries")
    }
    seen_keys: set[str] = set()
    added = 0
    skipped = 0
    paths = sorted(SUMMARIES_DIR.glob("*.md"))
    total = len(paths)
    print(f"[recall] Indexing {total} summaries…", file=sys.stderr)
    for i, path in enumerate(paths, 1):
        parsed = summary_session_key(path)
        if not parsed:
            continue
        key, date, agent = parsed
        seen_keys.add(key)
        mtime = path.stat().st_mtime
        if not force and existing.get(key) == mtime:
            skipped += 1
            continue
        title, body = parse_summary(path)
        con.execute(
            "INSERT INTO summaries(session_key, date, agent_id, title, path, mtime, summary_text) "
            "VALUES (?,?,?,?,?,?,?) "
            "ON CONFLICT(session_key) DO UPDATE SET "
            "  date=excluded.date, agent_id=excluded.agent_id, title=excluded.title, "
            "  path=excluded.path, mtime=excluded.mtime, summary_text=excluded.summary_text",
            (key, date, agent, title, str(path), mtime, body),
        )
        added += 1
        if i % 50 == 0 or i == total:
            print(f"  summaries {i}/{total} ({added} new, {skipped} unchanged)",
                  file=sys.stderr, flush=True)
    stale = set(existing) - seen_keys
    for key in stale:
        con.execute("DELETE FROM summaries WHERE session_key=?", (key,))
    con.commit()
    return added, skipped


# ---- Indexing: conversations -----------------------------------------------

def _discover_conversations(registry: dict) -> list[tuple[str, str, str, Path, str]]:
    results: list[tuple[str, str, str, Path, str]] = []
    seen: set[str] = set()
    if CONV_ARCHIVE.exists():
        for path in sorted(CONV_ARCHIVE.glob("*.jsonl")):
            parsed = archive_session_key(path)
            if not parsed:
                continue
            key, date, agent = parsed
            if key in seen:
                continue
            seen.add(key)
            results.append((key, date, agent, path, "archive"))
    if CONV_LIVE.exists():
        for path in sorted(CONV_LIVE.glob("*.jsonl")):
            uuid = path.stem
            parsed = live_session_key(uuid, registry)
            if not parsed:
                continue
            key, date, agent = parsed
            if key in seen:
                continue
            seen.add(key)
            results.append((key, date, agent, path, "live"))
    return results


def _reindex_conversations(
    con: sqlite3.Connection, *, force: bool = False,
) -> tuple[int, int]:
    registry = {}
    if REGISTRY.exists():
        try:
            registry = json.loads(REGISTRY.read_text())
        except (OSError, json.JSONDecodeError):
            registry = {}
    sources = _discover_conversations(registry)
    indexed: dict[str, float] = {
        row[0]: row[1]
        for row in con.execute(
            "SELECT source_path, source_mtime FROM chunks GROUP BY source_path"
        )
    }
    added = 0
    skipped = 0
    total = len(sources)
    print(f"[recall] Chunking {total} conversations…", file=sys.stderr)
    for i, (key, date, agent, path, source) in enumerate(sources, 1):
        try:
            mtime = path.stat().st_mtime
        except OSError:
            continue
        if not force and indexed.get(str(path)) == mtime:
            skipped += 1
            continue
        con.execute("DELETE FROM chunks WHERE source_path=?", (str(path),))
        turns = list(iter_conversation_turns(path))
        chunks = chunk_turns(turns)
        for idx, (text, tstart, tend) in enumerate(chunks):
            con.execute(
                "INSERT INTO chunks(session_key, date, agent_id, chunk_idx, turn_start, turn_end, "
                "  text, token_count, source, source_path, source_mtime) "
                "VALUES (?,?,?,?,?,?,?,?,?,?,?)",
                (key, date, agent, idx, tstart, tend, text,
                 _count_tokens(text), source, str(path), mtime),
            )
        # Store jsonl_path on the summary row for fast lookup by `files` and `dig --deep`.
        con.execute(
            "UPDATE summaries SET jsonl_path=? WHERE session_key=?",
            (str(path), key),
        )
        added += 1
        if i % 25 == 0 or i == total:
            print(f"  chunked {i}/{total} ({added} new, {skipped} unchanged)",
                  file=sys.stderr, flush=True)
    con.commit()
    return added, skipped


def embed_missing_chunks(
    con: sqlite3.Connection, api_key: str, *, progress: bool = True,
) -> int:
    rows = con.execute(
        "SELECT c.id, c.text FROM chunks c "
        "LEFT JOIN chunk_embeddings e ON e.chunk_id = c.id AND e.model = ? "
        "WHERE e.chunk_id IS NULL",
        (EMBED_MODEL,),
    ).fetchall()
    if not rows:
        return 0
    ids = [r[0] for r in rows]
    texts = [r[1] for r in rows]
    if progress:
        print(f"[recall] Embedding {len(texts)} chunks via {EMBED_MODEL}…",
              file=sys.stderr, flush=True)
    vectors = embed_many(api_key, texts, progress=progress)
    con.executemany(
        "INSERT OR REPLACE INTO chunk_embeddings(chunk_id, model, vector) VALUES (?,?,?)",
        [(cid, EMBED_MODEL, _pack_vec(v)) for cid, v in zip(ids, vectors)],
    )
    con.commit()
    return len(vectors)


# ---- File-touch extraction (lazy) ------------------------------------------

def _extract_session_files(jsonl_path: Path) -> list[str]:
    """Pull file paths from assistant tool_use blocks. Returns sorted unique list."""
    paths: set[str] = set()
    try:
        with jsonl_path.open("r", encoding="utf-8", errors="replace") as fp:
            for line in fp:
                line = line.strip()
                if not line:
                    continue
                try:
                    d = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if d.get("type") != "assistant":
                    continue
                msg = d.get("message", {}) or {}
                content = msg.get("content", [])
                if not isinstance(content, list):
                    continue
                for c in content:
                    if not isinstance(c, dict) or c.get("type") != "tool_use":
                        continue
                    inp = c.get("input", {}) or {}
                    if not isinstance(inp, dict):
                        continue
                    val = inp.get("file_path") or inp.get("path")
                    if val and isinstance(val, str):
                        paths.add(val)
                        if len(paths) >= FILES_CAP_PER_SESSION:
                            return sorted(paths)
    except OSError:
        pass
    return sorted(paths)


def _resolve_jsonl(con: sqlite3.Connection, session_key: str) -> Path | None:
    row = con.execute(
        "SELECT jsonl_path FROM summaries WHERE session_key=?", (session_key,)
    ).fetchone()
    if row and row[0]:
        p = Path(row[0])
        if p.exists():
            return p
    # Fall back to archive dir (strip any _N suffix).
    base = re.sub(r"_\d+$", "", session_key)
    candidate = CONV_ARCHIVE / f"{base}.jsonl"
    if candidate.exists():
        return candidate
    return None


def _ensure_files_indexed(
    con: sqlite3.Connection, session_keys: Iterable[str], *, progress: bool = True,
) -> int:
    """Backfill session_files for any listed keys not yet indexed. Returns count backfilled."""
    done = {row[0] for row in con.execute("SELECT session_key FROM files_indexed")}
    todo = [k for k in session_keys if k not in done]
    if not todo:
        return 0
    total = len(todo)
    if progress:
        print(f"[recall] Backfilling file-touch index for {total} session(s)…",
              file=sys.stderr, flush=True)
    now = time.time()
    for i, key in enumerate(todo, 1):
        jsonl = _resolve_jsonl(con, key)
        if jsonl is None:
            # Mark as indexed so we don't retry endlessly.
            con.execute(
                "INSERT OR REPLACE INTO files_indexed(session_key, indexed_at) VALUES (?,?)",
                (key, now),
            )
            continue
        paths = _extract_session_files(jsonl)
        if paths:
            con.executemany(
                "INSERT OR IGNORE INTO session_files(session_key, file_path) VALUES (?,?)",
                [(key, p) for p in paths],
            )
        con.execute(
            "INSERT OR REPLACE INTO files_indexed(session_key, indexed_at) VALUES (?,?)",
            (key, now),
        )
        if progress and (i % 25 == 0 or i == total):
            print(f"  files {i}/{total}", file=sys.stderr, flush=True)
    con.commit()
    return total


def _all_session_keys(con: sqlite3.Connection) -> list[str]:
    return [r[0] for r in con.execute("SELECT session_key FROM summaries")]


# ---- Search: lane 1 (FTS5 BM25) --------------------------------------------

def _tokenize_query(query: str) -> list[str]:
    raw = [t for t in re.split(r"\s+", query.strip()) if t]
    terms: list[str] = []
    for t in raw:
        cleaned = re.sub(r"[^\w\-./#]+", "", t)
        if cleaned:
            terms.append(cleaned)
    return terms


def _quote_fts_term(term: str) -> str:
    safe = term.replace('"', '""')
    return f'"{safe}"'


def _build_fts_query(terms: list[str], *, operator: str) -> str:
    """Build an FTS5 MATCH expression from cleaned terms.

    operator is 'AND' or 'OR'. Terms are always quote-wrapped (blunt-and-safe
    beats clever-conditional — eliminates hyphen/punct crashes).
    """
    if not terms:
        return ""
    quoted = [_quote_fts_term(t) for t in terms]
    if operator == "OR":
        return " OR ".join(quoted)
    # AND: space-separated is FTS5's implicit AND.
    return " ".join(quoted)


def _apply_stopword_strip(terms: list[str]) -> list[str]:
    """Drop stopwords if >2 terms. If strip would leave <2, abandon the strip."""
    if len(terms) <= 2:
        return terms
    stripped = [t for t in terms if t.lower() not in STOPWORDS]
    if len(stripped) < 2:
        return terms
    return stripped


@dataclass
class SummaryLane:
    hits: list[tuple[str, float, str, str, str]]
    relaxed_to_or: bool
    effective_terms: list[str]


def search_summaries(
    con: sqlite3.Connection, query: str, pool: int,
    since: str | None = None, until: str | None = None,
) -> SummaryLane:
    """Return summary-lane hits plus relaxation flags.

    Flow: tokenize → stopword-strip (if long) → AND → fall back to OR if
    AND found nothing and >1 term.
    """
    raw_terms = _tokenize_query(query)
    if not raw_terms:
        return SummaryLane([], False, [])
    effective = _apply_stopword_strip(raw_terms)

    def _run(op: str) -> list[tuple[str, float, str, str, str]]:
        fts_q = _build_fts_query(effective, operator=op)
        if not fts_q:
            return []
        sql = (
            "SELECT s.session_key, bm25(summaries_fts, 4.0, 1.0) AS bm, "
            "       s.date, s.agent_id, s.title "
            "FROM summaries_fts f JOIN summaries s ON s.rowid = f.rowid "
            "WHERE summaries_fts MATCH ? "
        )
        params: list = [fts_q]
        if since:
            sql += "AND s.date >= ? "
            params.append(since)
        if until:
            sql += "AND s.date <= ? "
            params.append(until)
        sql += "ORDER BY bm ASC LIMIT ?"
        params.append(pool)
        rows = con.execute(sql, params).fetchall()
        return [(r[0], -r[1], r[2], r[3], r[4] or "") for r in rows]

    hits = _run("AND")
    if hits:
        return SummaryLane(hits, False, effective)
    if len(effective) > 1:
        or_hits = _run("OR")
        if or_hits:
            return SummaryLane(or_hits, True, effective)
    return SummaryLane([], False, effective)


# ---- Search: lane 2 (semantic) ---------------------------------------------

def _cos(a: list[float], b: list[float]) -> float:
    if len(a) != len(b):
        return 0.0
    dot = 0.0
    na = 0.0
    nb = 0.0
    for x, y in zip(a, b):
        dot += x * y
        na += x * x
        nb += y * y
    if na == 0 or nb == 0:
        return 0.0
    return dot / (math.sqrt(na) * math.sqrt(nb))


@dataclass
class SemanticHit:
    session_key: str
    session_score: float
    best_chunk_id: int
    best_chunk_score: float
    date: str
    agent_id: str
    top_chunks: list[tuple[int, float]]  # [(chunk_id, score)] descending


def search_semantic(
    con: sqlite3.Connection, query_vec: list[float], pool: int,
    aggregation: str = "top3mean",
    since: str | None = None, until: str | None = None,
    session_key: str | None = None,
) -> list[SemanticHit]:
    sql = (
        "SELECT c.id, c.session_key, c.date, c.agent_id, e.vector "
        "FROM chunks c JOIN chunk_embeddings e "
        "  ON e.chunk_id = c.id AND e.model = ? "
    )
    params: list = [EMBED_MODEL]
    where = []
    if session_key:
        where.append("c.session_key = ?"); params.append(session_key)
    if since:
        where.append("c.date >= ?"); params.append(since)
    if until:
        where.append("c.date <= ?"); params.append(until)
    if where:
        sql += "WHERE " + " AND ".join(where)
    rows = con.execute(sql, params).fetchall()
    if not rows:
        return []

    per_session: dict[str, list[tuple[int, float, str, str]]] = {}
    for chunk_id, skey, date, agent, vec_blob in rows:
        vec = _unpack_vec(vec_blob)
        score = _cos(query_vec, vec)
        per_session.setdefault(skey, []).append((chunk_id, score, date, agent))

    hits: list[SemanticHit] = []
    for skey, entries in per_session.items():
        entries.sort(key=lambda x: x[1], reverse=True)
        top = entries[0]
        if aggregation == "top3mean":
            top3 = entries[:3]
            agg = sum(e[1] for e in top3) / len(top3)
        else:
            agg = top[1]
        hits.append(SemanticHit(
            session_key=skey,
            session_score=agg,
            best_chunk_id=top[0],
            best_chunk_score=top[1],
            date=top[2],
            agent_id=top[3],
            top_chunks=[(e[0], e[1]) for e in entries[:10]],
        ))
    hits.sort(key=lambda h: h.session_score, reverse=True)
    return hits[:pool]


# ---- RRF merge -------------------------------------------------------------

@dataclass
class Hit:
    session_key: str
    rrf_score: float
    date: str
    agent_id: str
    title: str
    summary_rank: int | None
    conv_rank: int | None
    conv_chunk_id: int | None
    conv_best_score: float | None
    bm25_score: float | None
    top_chunks: list[tuple[int, float]]  # from semantic lane


def rrf_merge(
    summary_hits: list[tuple[str, float, str, str, str]],
    semantic_hits: list[SemanticHit],
    k: int, w_summary: float, w_conv: float,
    meta_by_key: dict[str, tuple[str, str, str]] | None = None,
) -> list[Hit]:
    sum_rank: dict[str, int] = {}
    sum_info: dict[str, tuple[str, str, str, float]] = {}
    for i, (skey, bm, date, agent, title) in enumerate(summary_hits, 1):
        sum_rank[skey] = i
        sum_info[skey] = (date, agent, title, bm)

    conv_rank: dict[str, int] = {}
    conv_info: dict[str, SemanticHit] = {}
    for i, hit in enumerate(semantic_hits, 1):
        conv_rank[hit.session_key] = i
        conv_info[hit.session_key] = hit

    keys = set(sum_rank) | set(conv_rank)
    hits: list[Hit] = []
    for skey in keys:
        sr = sum_rank.get(skey)
        cr = conv_rank.get(skey)
        score = 0.0
        if sr is not None:
            score += w_summary / (k + sr)
        if cr is not None:
            score += w_conv / (k + cr)
        if skey in sum_info:
            date, agent, title, bm = sum_info[skey]
            bm25 = bm
        elif skey in conv_info:
            h = conv_info[skey]
            date, agent = h.date, h.agent_id
            title = (meta_by_key.get(skey, ("", "", ""))[2] if meta_by_key else "")
            bm25 = None
        else:
            date, agent, title, bm25 = "", "", "", None
        ch = conv_info.get(skey)
        hits.append(Hit(
            session_key=skey,
            rrf_score=score,
            date=date,
            agent_id=agent,
            title=title,
            summary_rank=sr,
            conv_rank=cr,
            conv_chunk_id=ch.best_chunk_id if ch else None,
            conv_best_score=ch.best_chunk_score if ch else None,
            bm25_score=bm25,
            top_chunks=ch.top_chunks if ch else [],
        ))
    hits.sort(key=lambda h: h.rrf_score, reverse=True)
    return hits


# ---- Output ----------------------------------------------------------------

def _snippet(text: str, query: str, width: int = 280) -> str:
    if not text:
        return ""
    tokens = [t.lower() for t in re.split(r"\W+", query) if t]
    lower = text.lower()
    best = -1
    for tok in tokens:
        i = lower.find(tok)
        if i != -1 and (best == -1 or i < best):
            best = i
    if best < 0:
        return text[:width].replace("\n", " ").strip()
    start = max(0, best - width // 3)
    end = min(len(text), start + width)
    snip = text[start:end].replace("\n", " ").strip()
    if start > 0:
        snip = "…" + snip
    if end < len(text):
        snip = snip + "…"
    return snip


def _summary_snippet(con: sqlite3.Connection, session_key: str, query: str) -> str:
    row = con.execute(
        "SELECT title, summary_text FROM summaries WHERE session_key=?",
        (session_key,),
    ).fetchone()
    if not row:
        return ""
    _, body = row
    parts = [p.strip() for p in (body or "").split("\n\n") if p.strip()]
    for p in parts[:3]:
        if p.startswith("#"):
            continue
        return _snippet(p, query, 280)
    return _snippet(body or "", query, 280)


def _session_blurb(
    con: sqlite3.Connection, session_key: str,
    target_len: int = 150, soft_min: int = 80,
) -> str:
    """Query-independent 1-sentence(-ish) session summary for find output.

    Heuristic: first non-heading paragraph from summary_text, first sentence
    (or two, if the first is short) up to ~target_len chars. Skips markdown
    headings and blank leading paragraphs.
    """
    row = con.execute(
        "SELECT summary_text FROM summaries WHERE session_key=?",
        (session_key,),
    ).fetchone()
    if not row or not row[0]:
        return ""
    body = row[0]
    # Pick first non-heading paragraph.
    para = ""
    for p in body.split("\n\n"):
        p = p.strip()
        if not p or p.startswith("#"):
            continue
        para = p
        break
    if not para:
        return ""
    # Flatten internal whitespace (multi-line paragraphs, bullet runs).
    para = re.sub(r"\s+", " ", para).strip()
    # Split into sentences.
    sentences = [s.strip() for s in re.split(r"(?<=[.!?])\s+", para) if s.strip()]
    if not sentences:
        return ""
    acc = sentences[0]
    i = 1
    # If the first sentence is a short stub ("Short session.") keep accumulating
    # until we have something informative or run out.
    while len(acc) < soft_min and i < len(sentences):
        acc = acc + " " + sentences[i]
        i += 1
    # Truncate if runs long.
    if len(acc) > target_len + 20:
        acc = acc[:target_len].rsplit(" ", 1)[0] + "…"
    return acc


def _chunk_text(con: sqlite3.Connection, chunk_id: int) -> str:
    row = con.execute("SELECT text FROM chunks WHERE id=?", (chunk_id,)).fetchone()
    return row[0] if row else ""


def _chunk_snippet(con: sqlite3.Connection, chunk_id: int, query: str) -> str:
    return _snippet(_chunk_text(con, chunk_id), query, 300)


def format_hits(
    con: sqlite3.Connection, hits: list[Hit], query: str,
    why: bool, passages: int,
) -> str:
    out: list[str] = []
    for i, h in enumerate(hits, 1):
        title = h.title or "(no title)"
        line1 = f"[{i:>2}] {h.date} {h.agent_id}  score: {h.rrf_score:.4f}"
        tags = []
        if h.summary_rank:
            tags.append(f"summary #{h.summary_rank}")
        if h.conv_rank:
            tags.append(f"conv #{h.conv_rank}")
        if tags:
            line1 += f"  ({', '.join(tags)})"
        out.append(line1)
        out.append(f"    {title}")
        blurb = _session_blurb(con, h.session_key)
        if blurb:
            out.append(f"    {blurb}")

        # Passage rendering.
        sr = h.summary_rank if h.summary_rank is not None else 10**9
        cr = h.conv_rank if h.conv_rank is not None else 10**9
        if passages <= 1:
            snippet, tag = "", ""
            if cr < sr and h.conv_chunk_id is not None:
                snippet = _chunk_snippet(con, h.conv_chunk_id, query)
                tag = "conv"
            elif h.summary_rank is not None:
                snippet = _summary_snippet(con, h.session_key, query)
                tag = "summary"
            elif h.conv_chunk_id is not None:
                snippet = _chunk_snippet(con, h.conv_chunk_id, query)
                tag = "conv"
            if snippet:
                out.append(f"    [{tag}] {snippet}")
        else:
            shown = 0
            for chunk_id, score in h.top_chunks[:passages]:
                snip = _chunk_snippet(con, chunk_id, query)
                if not snip:
                    continue
                shown += 1
                out.append(f"    [conv #{shown}  cos={score:.3f}] {snip}")
            if shown == 0 and h.summary_rank is not None:
                snip = _summary_snippet(con, h.session_key, query)
                if snip:
                    out.append(f"    [summary] {snip}")

        if why:
            detail = []
            if h.bm25_score is not None:
                detail.append(f"bm25={h.bm25_score:.2f}")
            if h.conv_best_score is not None:
                detail.append(f"cos={h.conv_best_score:.3f}")
            detail.append(f"rrf={h.rrf_score:.4f}")
            out.append(f"    [why] {' '.join(detail)}")
        out.append("")
    return "\n".join(out).rstrip()


# ---- Session key resolver --------------------------------------------------

def resolve_session_key(con: sqlite3.Connection, key_or_pattern: str) -> str | None:
    """Resolve bare agent-id / full key / unique prefix to a session_key.

    Prints disambiguation list + returns None on ambiguity.
    Prints a 'not found' note + returns None on no match.
    """
    row = con.execute(
        "SELECT session_key FROM summaries WHERE session_key=?", (key_or_pattern,)
    ).fetchone()
    if row:
        return row[0]

    rows = con.execute(
        "SELECT session_key, date FROM summaries WHERE agent_id=? ORDER BY date DESC",
        (key_or_pattern,),
    ).fetchall()
    if len(rows) == 1:
        return rows[0][0]
    if len(rows) > 1:
        print(f"Ambiguous: '{key_or_pattern}' matches multiple sessions:",
              file=sys.stderr)
        for skey, _ in rows:
            print(f"  {skey}", file=sys.stderr)
        return None

    rows = con.execute(
        "SELECT session_key FROM summaries WHERE session_key LIKE ? ORDER BY date DESC",
        (f"%{key_or_pattern}%",),
    ).fetchall()
    if len(rows) == 1:
        return rows[0][0]
    if len(rows) > 1:
        print(f"Ambiguous: '{key_or_pattern}' matches:", file=sys.stderr)
        for (skey,) in rows[:10]:
            print(f"  {skey}", file=sys.stderr)
        if len(rows) > 10:
            print(f"  ... ({len(rows) - 10} more)", file=sys.stderr)
        return None

    print(f"No session matches '{key_or_pattern}'.", file=sys.stderr)
    return None


