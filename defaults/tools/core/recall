# ---- Session key helpers ---------------------------------------------------

SUMMARY_NAME_RE = re.compile(
    r"^(?P<date>\d{4}-\d{2}-\d{2})-(?P<agent>[a-z0-9]+-[a-z0-9]+-[a-z0-9]+)(?:_(?P<sfx>\d+))?\.md$"
)
ARCHIVE_NAME_RE = re.compile(
    r"^(?P<date>\d{4}-\d{2}-\d{2})-(?P<agent>[a-z0-9]+-[a-z0-9]+-[a-z0-9]+)\.jsonl$"
)


def summary_session_key(path: Path) -> tuple[str, str, str] | None:
    m = SUMMARY_NAME_RE.match(path.name)
    if not m:
        return None
    date = m["date"]
    agent = m["agent"]
    sfx = m["sfx"]
    key = f"{date}-{agent}" + (f"_{sfx}" if sfx else "")
    return key, date, agent


def archive_session_key(path: Path) -> tuple[str, str, str] | None:
    m = ARCHIVE_NAME_RE.match(path.name)
    if not m:
        return None
    return f"{m['date']}-{m['agent']}", m["date"], m["agent"]


def live_session_key(uuid: str, registry: dict) -> tuple[str, str, str] | None:
    for agent_id, info in registry.items():
        if info.get("session_uuid") == uuid:
            started = info.get("started_at") or ""
            date = started[:10] if started else ""
            if not date:
                return None
            return f"{date}-{agent_id}", date, agent_id
    return None


# ---- Summary parsing -------------------------------------------------------

H1_RE = re.compile(r"^#\s+(.+)$", re.MULTILINE)


def parse_summary(path: Path) -> tuple[str, str]:
    """Return (title, body_text). Strips frontmatter if present."""
    try:
        raw = path.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return "", ""
    body = raw
    if body.startswith("---\n"):
        end = body.find("\n---\n", 4)
        if end != -1:
            body = body[end + 5:]
    m = H1_RE.search(body)
    title = ""
    if m:
        title = m.group(1).strip()
        title = re.sub(r"\s*\(beth-[a-z0-9-]+\)\s*$", "", title)
        title = re.sub(r"^\d{4}-\d{2}-\d{2}\s*[—-]\s*", "", title)
    return title, body


# ---- Conversation cleaning + chunking --------------------------------------

FILE_TOOLS = {"Read", "Write", "Edit", "NotebookEdit"}
QUERY_FIELDS = ("query", "prompt", "url", "file_path", "command", "description",
                "summary", "body", "channel", "to", "goal")

USER_SKIP_PREFIXES = (
    "[Request interrupted by user]",
    "[Request interrupted by user for tool use]",
)

SYSTEM_REMINDER_RE = re.compile(r"<system-reminder>.*?</system-reminder>", re.DOTALL)


def _extract_user_content(msg_content) -> str | None:
    if isinstance(msg_content, str):
        text = msg_content
    elif isinstance(msg_content, list):
        parts = []
        for c in msg_content:
            if isinstance(c, dict) and c.get("type") == "text":
                parts.append(c.get("text", ""))
        text = "\n".join(parts)
    else:
        return None
    if not text:
        return None
    stripped = text.strip()
    if not stripped:
        return None
    for pfx in USER_SKIP_PREFIXES:
        if stripped.startswith(pfx):
            return None
    text = SYSTEM_REMINDER_RE.sub("", text)
    text = text.strip()
    return text or None


def _extract_assistant_content(content_list) -> tuple[str, list[str]]:
    prose_parts: list[str] = []
    tools: list[str] = []
    if not isinstance(content_list, list):
        return "", []
    for c in content_list:
        if not isinstance(c, dict):
            continue
        ctype = c.get("type")
        if ctype == "text":
            t = c.get("text", "").strip()
            if t:
                prose_parts.append(t)
        elif ctype == "tool_use":
            tools.append(_format_tool_use(c))
    return "\n\n".join(prose_parts), tools


def _format_tool_use(tu: dict) -> str:
    name = tu.get("name", "?")
    clean = re.sub(r"^mcp__\w+__", "", name)
    inp = tu.get("input", {}) or {}
    if not isinstance(inp, dict):
        return f"[{clean}]"
    if clean in FILE_TOOLS:
        fp = inp.get("file_path") or inp.get("notebook_path") or ""
        return f"[{clean} {fp}]" if fp else f"[{clean}]"
    if clean == "message":
        action = inp.get("action", "?")
        target = inp.get("to") or inp.get("channel") or ""
        summ = (inp.get("summary") or "")[:80]
        return f"[{clean}/{action} {target} {summ!r}]"
    parts = [clean]
    for field in QUERY_FIELDS:
        if field in inp:
            val = str(inp[field])
            if val:
                val = val.replace("\n", " ")[:120]
                parts.append(f"{field}={val!r}")
                if len(parts) >= 4:
                    break
    return f"[{' '.join(parts)}]"


def iter_conversation_turns(path: Path) -> Iterator[tuple[str, str]]:
    """Yield (role, text) turns from a JSONL, cleaned."""
    try:
        fp = path.open("r", encoding="utf-8", errors="replace")
    except OSError:
        return
    with fp:
        for line in fp:
            line = line.strip()
            if not line:
                continue
            try:
                d = json.loads(line)
            except json.JSONDecodeError:
                continue
            t = d.get("type")
            if t == "user":
                msg = d.get("message", {}) or {}
                text = _extract_user_content(msg.get("content"))
                if text:
                    if len(text) > TURN_CAP_CHARS:
                        text = text[:TURN_CAP_CHARS] + "…"
                    yield ("user", text)
            elif t == "assistant":
                msg = d.get("message", {}) or {}
                prose, tools = _extract_assistant_content(msg.get("content"))
                combined_parts = []
                if prose:
                    if len(prose) > TURN_CAP_CHARS:
                        prose = prose[:TURN_CAP_CHARS] + "…"
                    combined_parts.append(prose)
                if tools:
                    combined_parts.append(" ".join(tools))
                combined = "\n".join(combined_parts).strip()
                if combined:
                    yield ("assistant", combined)


def chunk_turns(turns: Iterable[tuple[str, str]]) -> list[tuple[str, int, int]]:
    """Group turns into ~800-token chunks (cap 1500).

    Returns [(text, turn_start, turn_end)] where turn indices are
    1-based ordinals in the yielded turn stream.
    """
    chunks: list[tuple[str, int, int]] = []
    buf_lines: list[str] = []
    buf_tokens = 0
    buf_start = 1
    turn_no = 0
    for role, text in turns:
        turn_no += 1
        line = f"[{role.upper()}] {text}"
        tc = _count_tokens(line)
        if buf_tokens and (buf_tokens + tc > CHUNK_CAP_TOKENS):
            chunks.append(("\n\n".join(buf_lines), buf_start, turn_no - 1))
            buf_lines = [line]
            buf_tokens = tc
            buf_start = turn_no
            continue
        buf_lines.append(line)
        buf_tokens += tc
        if buf_tokens >= CHUNK_TARGET_TOKENS:
            chunks.append(("\n\n".join(buf_lines), buf_start, turn_no))
            buf_lines = []
            buf_tokens = 0
            buf_start = turn_no + 1
    if buf_lines:
        chunks.append(("\n\n".join(buf_lines), buf_start, turn_no))
    return [c for c in chunks if _count_tokens(c[0]) >= 20]


# ---- OpenAI embeddings ------------------------------------------------------

def _load_openai_key() -> str | None:
    key = os.environ.get("OPENAI_API_KEY")
    if key:
        return key.strip()
    if CRED_FILE.exists():
        try:
            return CRED_FILE.read_text().strip() or None
        except OSError:
            return None
    return None


def _embed_batch(api_key: str, texts: list[str]) -> list[list[float]]:
    body = json.dumps({"model": EMBED_MODEL, "input": texts}).encode("utf-8")
    req = urllib.request.Request(
        "https://api.openai.com/v1/embeddings",
        data=body,
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json",
        },
        method="POST",
    )
    backoff = 1.0
    last_err: Exception | None = None
    for _ in range(5):
        try:
            with urllib.request.urlopen(req, timeout=60) as resp:
                payload = json.loads(resp.read())
            data = payload.get("data") or []
            return [item["embedding"] for item in data]
        except urllib.error.HTTPError as e:
            last_err = e
            if e.code in (429, 500, 502, 503, 504):
                time.sleep(backoff)
                backoff *= 2
                continue
            raise
        except urllib.error.URLError as e:
            last_err = e
            time.sleep(backoff)
            backoff *= 2
    raise RuntimeError(f"OpenAI embeddings failed after retries: {last_err}")


def embed_many(api_key: str, texts: list[str], *, progress: bool = False) -> list[list[float]]:
    out: list[list[float]] = []
    total = len(texts)
    for i in range(0, total, EMBED_BATCH):
        batch = texts[i:i + EMBED_BATCH]
        vectors = _embed_batch(api_key, batch)
        out.extend(vectors)
        if progress:
            done = min(i + EMBED_BATCH, total)
            print(f"  embedded {done}/{total}", file=sys.stderr, flush=True)
    return out


def _pack_vec(v: list[float]) -> bytes:
    return struct.pack(f"{len(v)}f", *v)


def _unpack_vec(blob: bytes) -> list[float]:
    n = len(blob) // 4
    return list(struct.unpack(f"{n}f", blob))


