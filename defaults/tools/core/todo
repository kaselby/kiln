#!/usr/bin/env bash
# ---
# name: todo
# description: Add an item to the task inbox. Freeform text, timestamped automatically.
# arguments: "<item text>"
# ---

if [ -z "$1" ]; then
    echo "Usage: todo \"item text\""
    exit 1
fi

INBOX="${AGENT_HOME:?}/inbox/tasks.md"
echo "- [$(date '+%Y-%m-%d %H:%M')] $*" >> "$INBOX"
echo "Added to inbox: $*"
